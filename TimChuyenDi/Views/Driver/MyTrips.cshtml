@model IEnumerable<TimChuyenDi.Models.Trip>
@{
    ViewData["Title"] = "Chuyến xe của tôi";
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
    <h4><i class="bi bi-card-list"></i> Quản lý Chuyến Xe</h4>
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mt-2">@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mt-2">@TempData["Success"]</div>
    }
    <a asp-action="CreateTrip" class="btn btn-primary fw-bold"><i class="bi bi-plus-circle"></i> Đăng chuyến mới</a>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-6 mb-3">
            <div class="card shadow-sm border-info">
                <div class="card-header bg-info text-white fw-bold">
                    @item.FromStationNavigation.Province <i class="bi bi-arrow-right"></i> @item.ToStationNavigation.Province
                </div>
                <div class="card-body">
                    <div class="card-footer bg-white border-top-0 text-end">
                        <a asp-action="EditTrip" asp-route-id="@item.TripId" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil-square"></i> Sửa
                        </a>

                        <form asp-action="DeleteTrip" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@item.TripId" />
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bạn có chắc chắn muốn xóa/hủy chuyến xe này không?');">
                                <i class="bi bi-trash"></i> Xóa
                            </button>
                        </form>
                    </div>
                    <p class="mb-1"><strong>Xe tải:</strong> @item.Vehicle.PlateNumber</p>
                    <p class="mb-1">
                        <strong>Lịch trình:</strong>
                        @item.StartTime.ToString("dd/MM/yyyy HH:mm")
                        -
                        @(item.ArrivalTime?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa cập nhật")
                    </p>
                    <p class="mb-1"><strong>Giá mở đầu:</strong> <span class="text-success">@item.BasePrice.ToString("N0") đ</span></p>
                    <p class="mb-0"><strong>Chỗ trống hiện tại:</strong> <span class="text-danger fw-bold">@item.AvaiCapacityKg kg</span></p>
                </div>
            </div>
        </div>
    }
</div>
@model TimChuyenDi.Models.Trip
@{
    ViewData["Title"] = "Sửa Chuyến Xe";
}

<div class="card shadow-lg border-0 rounded-4 overflow-hidden" style="max-width: 900px; margin: 0 auto;">

    <!-- Header -->
    <div class="p-4 text-white"
         style="background: linear-gradient(135deg, #36b9cc, #4e73df);">
        <h4 class="fw-bold mb-1">
            <i class="bi bi-pencil-square"></i> Cập nhật chuyến xe #@Model.TripId
        </h4>
        <p class="mb-0 small opacity-75">
            Điều chỉnh thông tin chuyến để tối ưu vận chuyển
        </p>
    </div>

    <!-- Body -->
    <div class="p-4 bg-white">
        <form asp-action="EditTrip" method="post">
            <input type="hidden" name="TripId" value="@Model.TripId" />

            <div class="row g-3">

                <!-- Xe + Giá -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Xe vận tải</label>
                    <select name="VehicleId"
                            class="form-select rounded-3 shadow-sm"
                            asp-items="ViewBag.Vehicles"
                            asp-for="VehicleId" required>
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Giá mở đầu (VNĐ)</label>
                    <input type="number" step="1000"
                           name="BasePrice"
                           class="form-control rounded-3 shadow-sm"
                           value="@Model.BasePrice" required />
                </div>

                <!-- Điểm đi -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-primary">Điểm xuất phát</label>
                    <select name="FromLocation"
                            class="form-select rounded-3 shadow-sm"
                            asp-items="ViewBag.Locations"
                            asp-for="FromStationNavigation" required>
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Địa chỉ chi tiết</label>
                    <input type="text"
                           name="FromAddress"
                           class="form-control rounded-3 shadow-sm"
                           value="@Model.FromStationNavigation.Address" required />
                </div>

                <!-- Điểm đến -->
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-success">Điểm đến</label>
                    <select name="ToLocation"
                            class="form-select rounded-3 shadow-sm"
                            asp-items="ViewBag.Locations"
                            asp-for="ToStationNavigation.Address" required>
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Địa chỉ trả hàng</label>
                    <input type="text"
                           name="ToAddress"
                           class="form-control rounded-3 shadow-sm"
                           value="@Model.ToStationNavigation.Address" required />
                </div>

                <!-- Thông tin chuyến -->
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Trọng tải (kg)</label>
                    <input type="number"
                           name="AvaiCapacityKg"
                           class="form-control rounded-3 shadow-sm"
                           value="@Model.AvaiCapacityKg" required />
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">Thời gian xuất phát</label>
                    <input type="datetime-local"
                           name="StartTime"
                           class="form-control rounded-3 shadow-sm"
                           value="@Model.StartTime.ToString("yyyy-MM-ddTHH:mm")"
                           required />
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">Thời gian đến</label>
                    <input type="datetime-local"
                           name="ArrivalTime"
                           class="form-control rounded-3 shadow-sm"
                           value="@(Model.ArrivalTime.HasValue ? Model.ArrivalTime.Value.ToString("yyyy-MM-ddTHH:mm") : "")"
                           required />
                </div>

                <!-- Button -->
                <div class="col-12 text-end mt-4">
                    <a asp-action="MyTrips"
                           class="btn btn-outline-secondary px-4 py-2 rounded-3">
                        Hủy
                    </a>

                    <button type="submit"
                            class="btn text-white fw-bold px-4 py-2 rounded-3"
                            style="background: linear-gradient(135deg, #36b9cc, #4e73df); border: none;">
                        <i class="bi bi-save"></i> Lưu thay đổi
                    </button>
                </div>

            </div>
        </form>
    </div>
</div>
@model IEnumerable<TimChuyenDi.Models.Vehicle>
@{
    ViewData["Title"] = "Quản lý Phương tiện";
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-4">
    <h4><i class="bi bi-truck text-primary"></i> Quản lý Phương tiện Của Bạn</h4>
    <a asp-action="AddVehicle" class="btn btn-primary fw-bold">
        <i class="bi bi-plus-circle"></i> Thêm xe mới
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Hình ảnh</th>
                        <th>Biển số xe</th>
                        <th>Loại xe</th>
                        <th>Trọng tải (Kg)</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                Chưa có phương tiện nào. Hãy thêm xe mới!
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    @if (!string.IsNullOrEmpty(item.VehicleImage))
                                    {
                                        <img src="@item.VehicleImage" alt="Giấy tờ xe @item.PlateNumber" class="img-thumbnail" style="width: 80px; height: 60px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light text-muted d-flex align-items-center justify-content-center rounded" style="width: 80px; height: 60px;">
                                            <i class="bi bi-image"></i>
                                        </div>
                                    }
                                </td>
                                <td class="fw-bold">@item.PlateNumber</td>
                                <td><span class="badge bg-secondary">@item.VehicleType.TypeName</span></td>
                                <td class="text-danger fw-bold">@item.CapacityKg.ToString("N0")</td>
                                <td>
                                    @if (item.Status == 1)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Đã duyệt</span>
                                    }
                                    else if (item.Status == 2)
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Bị từ chối</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Chờ duyệt</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group" role="group">
                                        <a asp-action="EditVehicle" asp-route-id="@item.VehicleId" class="btn btn-sm btn-outline-primary" title="Sửa thông tin">
                                            <i class="bi bi-pencil-square"></i> Sửa
                                        </a>
                                        <form asp-action="DeleteVehicle" asp-route-id="@item.VehicleId" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa chiếc xe này không? Hành động này không thể hoàn tác.');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger btn-delete" title="Xóa">
                                                <i class="bi bi-trash"></i> Xóa
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .btn-delete {
        border-top-left-radius: 0;
        border-bottom-left-radius: 0;
    }
</style>

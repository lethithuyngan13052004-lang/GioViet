@model TimChuyenDi.Models.Trip
@{
    ViewData["Title"] = "Đăng Chuyến Xe & Lập Lộ Trình";
}

<!-- Leaflet & Routing Assets -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />

<!-- Toast Container (Standard UI) -->
<div class="toast-container position-fixed top-0 end-0 p-4" style="z-index: 1060; margin-top: 20px;">
    <div id="actionToast" class="toast align-items-center border-0 shadow-lg rounded-4" role="alert" aria-live="assertive" aria-atomic="true" style="backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border-left: 6px solid !important;">
        <div class="d-flex">
            <div class="toast-body fw-bold px-3 py-3" id="toastMessage" style="font-size: 1rem;">
                Thao tác thành công!
            </div>
            <button type="button" class="btn-close me-3 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<style>
    #map { height: 650px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.08); box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
    .card-trip { border: none; border-radius: 20px; overflow: hidden; }
    .form-section-title { font-weight: 700; color: #0d6efd; border-left: 4px solid #0d6efd; padding-left: 10px; margin-bottom: 20px; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .trip-type-card { cursor: pointer; border: 2px solid #f1f3f5; transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); background: #fdfdfe; border-radius: 12px !important; }
    .trip-type-card:hover { border-color: #0d6efd; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(13, 110, 253, 0.08); }
    .trip-type-radio:checked + .trip-type-card { border-color: #0d6efd; background-color: #f0f7ff; box-shadow: 0 5px 15px rgba(13, 110, 253, 0.12); }
    
    .intermediate-station { display: flex; align-items: center; background: #fff; border: 1px solid #e9ecef; padding: 12px; border-radius: 12px; margin-bottom: 10px; transition: 0.2s; }
    .intermediate-station:hover { border-color: #ffc107; background: #fffcf5; }
    
    .select-highlight { animation: highlight-fade 1.5s ease-out; }
    @@keyframes highlight-fade {
        0% { background-color: rgba(13, 110, 253, 0.15); box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.2); }
        100% { background-color: transparent; box-shadow: none; }
    }
    .leaflet-popup-content-wrapper { border-radius: 12px; padding: 5px; }
    .leaflet-popup-tip { box-shadow: none; }

</style>

<div class="container-fluid py-4">
    <form asp-action="CreateTrip" method="post" id="tripForm">
        <div class="row g-4">
            <!-- Left Panel: Form Data -->
            <div class="col-lg-4">
                <div class="card card-trip shadow-lg h-100">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-truck me-2"></i>Thông Tin Chuyến Xe</h5>
                    </div>
                    <div class="card-body p-4 overflow-auto" style="max-height: 80vh;">
                        
                        <div class="form-section-title">1. Chọn Phương Tiện & Loại Hình</div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Chọn xe vận tải</label>
                            <select name="VehicleId" id="vehicleSelect" class="form-select select2-bootstrap" required>
                                <option value="">-- Chọn xe của bạn --</option>
                                @foreach (var v in ViewBag.Vehicles)
                                {
                                    <option value="@v.VehicleId" data-kg="@v.CapacityKg" data-m3="@v.CapacityM3">
                                        @v.PlateNumber (@v.VehicleType.TypeName - @v.CapacityKg kg)
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Chọn loại chuyến đi</label>

                            <div class="d-flex flex-column gap-2">
                                @foreach (var type in ViewBag.TripTypes)
                                {
                                    <div>
                                        <input type="radio"
                                            name="RouteType"
                                            value="@type.IdType"
                                            id="type-@type.IdType"
                                            class="d-none trip-type-radio"
                                            required
                                            @(type.IdType == 1 ? "checked" : "")>

                                        <label for="type-@type.IdType" class="trip-type-card p-2 rounded w-100">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="fs-5">
                                                    @(type.Type == "Direct" ? "🚗" : "📦")
                                                </div>

                                                <div>
                                                    <div class="fw-bold">
                                                        @(type.Type == "Direct" ? "Chuyến riêng" : "Chuyến ghép")
                                                    </div>

                                                    <small class="text-muted">
                                                        @(type.Type == "Direct"
                                                            ? "Không ghép đơn, đi thẳng đến điểm đến"
                                                            : "Nhận thêm đơn khác trên cùng tuyến đường")
                                                    </small>
                                                </div>
                                            </div>
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="form-section-title">2. Lập Lộ Trình</div>

                        <!-- START STATION -->
                        <div class="p-3 bg-light rounded border border-primary border-opacity-25 mb-3">
                            <label class="form-label fw-bold text-primary"><i class="bi bi-geo-alt-fill"></i> ĐIỂM XUẤT PHÁT</label>
                            <select id="provinceStart" class="form-select select2-bootstrap mb-2" onchange="filterStations('start')">
                                <option value="">-- Chọn Tỉnh/Thành --</option>
                                @foreach (var p in ViewBag.Provinces)
                                {
                                    <option value="@p.ProvinceId">@p.ProvinceName</option>
                                }
                            </select>
                            <select name="FromStation" id="fromStation" class="form-select select2-stations" required disabled>
                                <option value="">-- Chọn trạm --</option>
                            </select>
                        </div>

                        <!-- INTERMEDIATE STATIONS -->
                        <div id="intermediateStationsContainer" class="mb-3" style="display: none;">
                            <label class="form-label fw-bold text-warning"><i class="bi bi-plus-circle-fill"></i> CÁC TRẠM DỪNG (PHỤ)</label>
                            <div id="stopsList">
                                <!-- Dynamic stops -->
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-warning w-100 mt-1 fw-bold rounded-pill" onclick="addStop()">
                                <i class="bi bi-plus-lg"></i> THÊM TRẠM DỪNG PHỤ
                            </button>
                        </div>

                        <!-- END STATION -->
                        <div class="p-3 bg-light rounded border border-success border-opacity-25 mb-4">
                            <label class="form-label fw-bold text-success"><i class="bi bi-flag-fill"></i> ĐIỂM ĐẾN NƠI</label>
                            <select id="provinceEnd" class="form-select select2-bootstrap mb-2" onchange="filterStations('end')">
                                <option value="">-- Chọn Tỉnh/Thành --</option>
                                @foreach (var p in ViewBag.Provinces)
                                {
                                    <option value="@p.ProvinceId">@p.ProvinceName</option>
                                }
                            </select>
                            <select name="ToStation" id="toStation" class="form-select select2-stations" required disabled>
                                <option value="">-- Chọn trạm --</option>
                            </select>
                        </div>

                        <div class="form-section-title">3. Thời Gian & Giá Cước</div>

                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label class="form-label fw-bold">Giá cơ bản (VNĐ)</label>
                                <input type="number" name="BasePrice" class="form-control" required placeholder="Ví dụ: 500000">
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold">Sức chứa (kg)</label>
                                <input type="number" name="AvaiCapacityKg" id="capacityInput" class="form-control" required>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <label class="form-label fw-bold">Giờ xuất phát</label>
                                <input type="datetime-local" name="StartTime" id="startTime" class="form-control" required>
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold text-primary">Ngày tới (Dự kiến)</label>
                                <input type="datetime-local" name="ArrivalTime" id="arrivalTime" class="form-control" required>
                                <small class="text-muted" id="etaMessage"></small>
                            </div>
                        </div>

                        <input type="hidden" name="Distance" id="distanceInput">
                        <input type="hidden" name="intermediateStations" id="hiddenStops">

                        <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-lg rounded-pill" onclick="return validateAndSubmit()">
                            <i class="bi bi-check-circle-fill me-2"></i> XÁC NHẬN ĐĂNG CHUYẾN
                        </button>
                    </div>
                </div>
            </div>

            <!-- Right Panel: Map -->
            <div class="col-lg-8">
                <div class="card card-trip shadow-lg h-100">
                    <div class="card-body p-0 position-relative">
                        <div id="map"></div>
                        <div class="position-absolute bottom-0 start-0 p-3 w-100" style="z-index: 1000;">
                            <div class="bg-white p-3 rounded-pill shadow-lg d-flex justify-content-around align-items-center mx-auto" style="max-width: 600px;">
                                <div class="text-center px-4">
                                    <span class="d-block small text-muted">Tổng quãng đường</span>
                                    <span class="h5 fw-bold mb-0 text-primary" id="totalDistance">0 km</span>
                                </div>
                                <div class="vr"></div>
                                <div class="text-center px-4">
                                    <span class="d-block small text-muted">Thời gian di chuyển</span>
                                    <span class="h5 fw-bold mb-0 text-success" id="totalTime">0 h</span>
                                </div>
                                <div class="vr"></div>
                                 <div class="text-center px-4">
                                     <button type="button" class="btn btn-sm btn-outline-secondary" onclick="resetMap()">
                                         <i class="bi bi-arrow-repeat"></i> Reset Map
                                     </button>
                                 </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Scripts -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0/dist/js/select2.min.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.js"></script>

<script>
    var map, routingControl;
    var locationMarkers = L.layerGroup();
    var persistentMarkers = L.layerGroup(); // Layer for selected/permanent stations
    var lastTotalTimeSeconds = 0;

    // Fixed Icon Definitions
    const iconBase = "https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-";
    const shadowUrl = "https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png";
    const createIcon = (color) => L.icon({
        iconUrl: iconBase + color + ".png", shadowUrl: shadowUrl,
        iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34], shadowSize: [41, 41]
    });

    const startIcon = createIcon('blue');
    const endIcon = createIcon('green');
    const stopIcon = createIcon('orange');

    /* ============================================================
       🔥 CRITICAL: TOGGLE LISTENER (TOP PRIORITY - DO NOT MOVE)
       Placed here to ensure it binds even if other UI plugins fail.
    ============================================================ */
    $(document).on('change', 'input[name="RouteType"]', function () {
        var val = $(this).val();
        console.log("TripType Changed to:", val);
        updateIntermediateSection(val);
    });

    $(document).ready(function () {
        try {
            console.log("Initializing UI Components...");
            initMap();
            locationMarkers.addTo(map);
            persistentMarkers.addTo(map);
        } catch(e) { console.error("Map Init Error:", e); }

        try {
            initSelect2();
        } catch(e) { console.error("Select2 Init Error:", e); }

        // Initial state check
        var initVal = $('input[name="RouteType"]:checked').val();
        if (initVal) updateIntermediateSection(initVal);

        // Vehicle Capacity Auto-fill
        $(document).on('change', '#vehicleSelect', function () {
            var kg = $(this).find(':selected').data('kg');
            $('#capacityInput').val(kg);
        });

        $('#fromStation, #toStation').on('change', updateRoute);
        $('#startTime').on('change', () => calculateArrivalTime(lastTotalTimeSeconds));
    });

    /* ✅ LOGIC ẨN TRẠM PHỤ (ROBUST VERSION) */
    function updateIntermediateSection(val) {
        let container = $('#intermediateStationsContainer');
        if (!container.length) return;

        // Ensure val is compared as a string and handle whitespace
        var value = (val || "").toString().trim();

        if (value == "2") { // 2 = Shared (Ghép chuyến)
            container.stop(true, true).slideDown(250);
            console.log("Showing Intermediate Container");
        } else { // 1 = Direct (Chuyến riêng)
            container.stop(true, true).slideUp(250, function() {
                $('#stopsList').empty();
                updateRoute();
            });
            console.log("Hiding Intermediate Container");
        }
    }

    function initMap() {
        map = L.map('map').setView([16.0544, 108.2022], 6);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        // Khóa map tại Việt Nam theo yêu cầu Admin
        var vnBounds = [[8.18, 102.14], [23.4, 109.46]];
        map.setMaxBounds(vnBounds);
        map.options.minZoom = 5;

        routingControl = L.Routing.control({
            waypoints: [],
            routeWhileDragging: false,
            show: false,
            router: L.Routing.osrmv1({
                serviceUrl: 'https://router.project-osrm.org/trip/v1/driving', // Optimized for route calculation
                profile: 'driving'
            }),
            lineOptions: { 
                styles: [{ color: '#0d6efd', opacity: 0.8, weight: 6 }] 
            },
            createMarker: () => null // We handle our own persistent markers
        }).addTo(map);

        routingControl.on('routesfound', function (e) {
            var summary = e.routes[0].summary;
            lastTotalTimeSeconds = summary.totalTime;
            $('#totalDistance').text((summary.totalDistance / 1000).toFixed(1) + " km");
            $('#totalTime').text((summary.totalTime / 3600).toFixed(1) + " h");
            $('#distanceInput').val((summary.totalDistance / 1000).toFixed(1));
            calculateArrivalTime(summary.totalTime);
        });
    }

    function initSelect2() {
        if ($.fn.select2) {
            $('.select2-bootstrap').select2({ theme: 'bootstrap-5', width: '100%' });
            $('.select2-stations').select2({ theme: 'bootstrap-5', width: '100%' });

            $(document).on('select2:open', () => {
                setTimeout(() => {
                    let searchField = document.querySelector('.select2-container--open .select2-search__field');
                    if (searchField) searchField.focus();
                }, 50);
            });
            console.log("Select2 Initialized Successfully.");
        } else {
            console.warn("Select2 plugin not found. Falling back to native selects.");
        }
    }

    function showToast(message, isError = false) {
        var toastEl = document.getElementById('actionToast');
        var toastMsg = document.getElementById('toastMessage');
        toastMsg.innerText = message;
        
        if (isError) {
            toastEl.style.backgroundColor = 'rgba(248, 215, 218, 0.9)'; 
            toastEl.style.color = '#842029'; 
            toastEl.style.borderLeftColor = '#dc3545'; 
        } else {
            toastEl.style.backgroundColor = 'rgba(209, 231, 221, 0.9)'; 
            toastEl.style.color = '#0f5132'; 
            toastEl.style.borderLeftColor = '#198754';
        }
        var toast = new bootstrap.Toast(toastEl, { delay: 1500 });
        toast.show();
    }

    function updateRoute() {
        persistentMarkers.clearLayers();
        var waypoints = [];
        
        // 1. Start Station (Blue)
        var start = $('#fromStation option:selected');
        if (start.val()) {
            var latLng = L.latLng(parseFloat(start.data('lat')), parseFloat(start.data('lng')));
            waypoints.push(latLng);
            L.marker(latLng, { icon: startIcon }).addTo(persistentMarkers).bindPopup("<b>Điểm bắt đầu</b>: " + start.text());
        }

        // 2. Intermediate Stations (Orange)
        $('.intermediate-select').each(function () {
            var opt = $(this).find('option:selected');
            if (opt.val()) {
                var latLng = L.latLng(parseFloat(opt.data('lat')), parseFloat(opt.data('lng')));
                waypoints.push(latLng);
                L.marker(latLng, { icon: stopIcon }).addTo(persistentMarkers).bindPopup("<b>Trạm dừng phụ</b>: " + opt.text());
            }
        });

        // 3. End Station (Green)
        var end = $('#toStation option:selected');
        if (end.val()) {
            var latLng = L.latLng(parseFloat(end.data('lat')), parseFloat(end.data('lng')));
            waypoints.push(latLng);
            L.marker(latLng, { icon: endIcon }).addTo(persistentMarkers).bindPopup("<b>Điểm đến</b>: " + end.text());
        }

        if (waypoints.length >= 2) {
            routingControl.setWaypoints(waypoints);
            
            // Auto focus viewport to fit new markers if they are changed significantly
            if (waypoints.length > 0) {
                var group = L.featureGroup(waypoints.map(w => L.marker(w)));
                map.fitBounds(group.getBounds().pad(0.2));
            }
        }
    }

    /* ✅ LOGIC ADD STOP (Restored) */
    function addStop() {
        var stopCount = $('.intermediate-select').length + 1;
        var html = `
        <div class="intermediate-station" id="stopRow_${stopCount}">
            <select class="form-select select2-bootstrap mb-2 province-stop" onchange="loadStopStations(${stopCount})">
                <option value="">-- Tỉnh dừng --</option>
                @foreach (var p in ViewBag.Provinces) {
                    <option value="@p.ProvinceId">@p.ProvinceName</option>
                }
            </select>
            <select class="form-select select2-stations intermediate-select" onchange="updateRoute()" disabled>
                <option value="">-- Trạm phụ --</option>
            </select>
            <button type="button" class="btn btn-link text-danger p-0 ms-2" onclick="removeStop(${stopCount})">
                <i class="bi bi-trash"></i>
            </button>
        </div>
        `;
        $('#stopsList').append(html);
        initSelect2();
        let el = $(`#stopRow_${stopCount}`);
        el.hide().slideDown(250).css('opacity', 0).animate({ opacity: 1 }, 200);
    }

    function removeStop(id) {
        $(`#stopRow_${id}`).animate({ opacity: 0, height: 0 }, 200, function () { $(this).remove(); updateRoute(); });
    }

    async function loadStopStations(id) {
        var pId = $(`#stopRow_${id} .province-stop`).val();
        var target = $(`#stopRow_${id} .intermediate-select`);
        if (!pId) return;
        target.prop('disabled', false).html('<option>Loading...</option>');
        const res = await fetch(`/Driver/GetStationsByProvince?provinceId=${pId}`);
        const data = await res.json();
        let html = '<option value="">-- Chọn trạm --</option>';
        data.forEach(s => { html += `<option value="${s.id}" data-lat="${s.lat}" data-lng="${s.lng}">${s.name}</option>`; });
        target.html(html).trigger('change.select2');
    }

    function calculateArrivalTime(seconds) {
        var start = $('#startTime').val();
        if (!start || !seconds) return;
        var arrival = new Date(new Date(start).getTime() + seconds * 1000);
        var formatted = arrival.getFullYear() + '-' + ('0' + (arrival.getMonth() + 1)).slice(-2) + '-' + ('0' + arrival.getDate()).slice(-2) + 'T' + ('0' + arrival.getHours()).slice(-2) + ':' + ('0' + arrival.getMinutes()).slice(-2);
        $('#arrivalTime').val(formatted);
        $('#etaMessage').html(`<i class="bi bi-lightning-auto"></i> ETA tự động cập nhật`);
    }

    async function filterStations(type) {
        var pId = type === 'start' ? $('#provinceStart').val() : $('#provinceEnd').val();
        var targetSelect = type === 'start' ? $('#fromStation') : $('#toStation');
        if (!pId) return;
        targetSelect.prop('disabled', false).html('<option value="">-- Đang nạp trạm... --</option>');
        try {
            const response = await fetch(`/Driver/GetStationsByProvince?provinceId=${pId}`);
            const stations = await response.json();
            let html = '<option value="">-- Chọn trạm --</option>';
            stations.forEach(s => { html += `<option value="${s.id}" data-lat="${s.lat}" data-lng="${s.lng}">${s.name}</option>`; });
            targetSelect.html(html).trigger('change.select2');
            showProvinceMarkers(stations, type);
        } catch (error) { console.error('Lỗi tải trạm:', error); }
    }

    function showProvinceMarkers(stations, type) {
        locationMarkers.clearLayers();
        var bounds = [];
        stations.forEach(s => {
            if (s.lat && s.lng) {
                bounds.push([s.lat, s.lng]);
                var iconUrl = (type === 'start') ? 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-blue.png' : 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-green.png';
                var marker = L.marker([s.lat, s.lng], {
                    icon: L.icon({ iconUrl: iconUrl, shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png', iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34], shadowSize: [41, 41] })
                }).bindPopup(`
                    <div class="text-center p-1">
                        <h6 class="fw-bold mb-1 text-primary">${s.name}</h6>
                        <p class="small text-muted mb-2">${s.address}<br/>
                            <span class="badge bg-light text-dark border fw-normal">${s.wardName ? s.wardName + ', ' : ''}${s.districtName ? s.districtName + ', ' : ''}${s.province}</span>
                        </p>
                        <button type='button' class='btn btn-sm btn-primary w-100 rounded-pill fw-bold shadow-sm' onclick='selectFromMap(${s.id}, "${type}", "${s.name}")'>Chọn Trạm Này</button>
                    </div>
                `);
                locationMarkers.addLayer(marker);
            }
        });
        if (bounds.length > 0) { map.fitBounds(bounds, { padding: [50, 50], maxZoom: 16 }); }
    }

    function selectFromMap(id, type, stationName) {
        var targetSelect = (type === 'start') ? $('#fromStation') : (type === 'end') ? $('#toStation') : null;
        if (targetSelect) {
            targetSelect.val(id).trigger('change');
            map.closePopup();
            showToast(`Đã chọn trạm: ${stationName}`);
            var selectContainer = targetSelect.next('.select2-container');
            selectContainer.addClass('select-highlight');
            setTimeout(() => selectContainer.removeClass('select-highlight'), 1500);
        }
    }

    function validateAndSubmit() {
        var stops = [];
        $('.intermediate-select').each(function() { if ($(this).val()) stops.push($(this).val()); });
        $('#hiddenStops').val(stops.join(','));
        if (!$('#fromStation').val() || !$('#toStation').val()) { alert("Vui lòng chọn trạm đi và trạm đến!"); return false; }
        return true;
    }

    function resetMap() { locationMarkers.clearLayers(); routingControl.setWaypoints([]); map.setView([16.0544, 108.2022], 6); }
</script>
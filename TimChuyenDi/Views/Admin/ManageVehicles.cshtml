@model IEnumerable<TimChuyenDi.Models.Vehicle>
@{
    ViewData["Title"] = "Quản lý Phương tiện";
}

<h4 class="mt-4 mb-4"><i class="bi bi-truck-front-fill"></i> Quản lý Phương Tiện Vận Tải</h4>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm border-primary">
            <div class="card-header bg-primary text-white fw-bold">
                Thêm Xe Mới
            </div>
            <div class="card-body bg-light">
                <form asp-action="AddVehicle" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Biển số xe</label>
                        <input type="text" name="plateNumber" class="form-control" required placeholder="VD: 29C-123.45" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Trọng tải tối đa (kg)</label>
                        <input type="number" name="maxCapacityKg" class="form-control" required placeholder="VD: 5000" />
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary fw-bold">Lưu Phương Tiện</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Mã xe</th>
                                <th>Biển kiểm soát</th>
                                <th>Trọng tải tối đa</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-muted">#@item.VehicleId</td>
                                    <td class="fw-bold"><span class="badge bg-secondary fs-6">@item.PlateNumber</span></td>
                                    <td class="text-danger fw-bold">@item.MaxCapacityKg kg</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
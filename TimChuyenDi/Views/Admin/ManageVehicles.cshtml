@model IEnumerable<TimChuyenDi.Models.Vehicle>
@{
    ViewData["Title"] = "Duyệt Phương tiện";
}

<div class="container-fluid py-4" style="max-width: 1200px;">
    <h3 class="fw-bold mb-4"><i class="bi bi-truck-front-fill me-2"></i>Xét Duyệt Phương Tiện Vận Tải</h3>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-primary text-white rounded-top-4 py-3 d-flex justify-content-between align-items-center">
            <span class="fw-bold"><i class="bi bi-card-checklist me-2"></i>Danh sách yêu cầu xét duyệt xe</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3 text-muted">Mã xe</th>
                            <th class="text-center">Hình ảnh</th>
                            <th>Biển kiểm soát</th>
                            <th>Tài xế</th>
                            <th>Loại xe</th>
                            <th class="text-end">Tải trọng</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-end pe-3 w-100px">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-5"><i class="bi bi-inbox fs-1 d-block mb-2"></i>Chưa có phương tiện nào yêu cầu xét duyệt.</td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-muted ps-3 small fw-bold">#@item.VehicleId</td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.VehicleImage))
                                    {
                                        <a href="javascript:void(0)" class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 text-decoration-none px-3 py-2 rounded-pill shadow-sm" onclick="openImageViewer('@item.VehicleImage', 'Giấy tờ xe biển số @item.PlateNumber')">
                                            <i class="bi bi-image me-1"></i> Xem Giấy Tờ
                                        </a>
                                    }
                                    else
                                    {
                                        <div class="bg-light text-muted d-flex align-items-center justify-content-center mx-auto rounded-3" style="width: 70px; height: 50px;">
                                            <i class="bi bi-camera-video-off"></i>
                                        </div>
                                    }
                                </td>
                                <td><span class="badge bg-secondary rounded-pill px-3 fs-6">@item.PlateNumber</span></td>
                                <td>
                                    <div class="fw-bold text-dark"><i class="bi bi-person text-muted me-1"></i>@item.Driver?.Name</div>
                                    <div class="small text-muted"><i class="bi bi-telephone me-1"></i>@item.Driver?.Phone</div>
                                </td>
                                <td class="text-primary fw-semibold">@item.VehicleType?.TypeName</td>
                                <td class="text-end">
                                    <div class="text-danger fw-bold">@item.CapacityKg.ToString("N0") kg</div>

                                </td>
                                <td class="text-center">
                                    @if (item.Status == 1)
                                    {
                                        <span class="badge bg-success rounded-pill px-3 py-2"><i class="bi bi-check-circle me-1"></i> Đã duyệt</span>
                                    }
                                    else if (item.Status == 2)
                                    {
                                        <span class="badge bg-danger rounded-pill px-3 py-2"><i class="bi bi-x-circle me-1"></i> Bị từ chối</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill px-3 py-2"><i class="bi bi-hourglass-split me-1"></i> Chờ duyệt</span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    @if (item.Status == 0)
                                    {
                                        <div class="d-flex justify-content-end gap-2">
                                            <form asp-action="ApproveVehicle" asp-route-id="@item.VehicleId" method="post" class="m-0">
                                                <button type="submit" class="btn btn-sm btn-success rounded-pill fw-bold" title="Duyệt xe" onclick="return confirm('Xác nhận duyệt xe biển số @item.PlateNumber để tài xế có thể nhận chuyến?');">
                                                    <i class="bi bi-check2-circle me-1"></i>Duyệt
                                                </button>
                                            </form>
                                            <form asp-action="RejectVehicle" asp-route-id="@item.VehicleId" method="post" class="m-0">
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle" title="Từ chối xe" style="width: 32px; height: 32px; padding: 0;" onclick="return confirm('Bạn có chắc muốn từ chối xe @item.PlateNumber không?');">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small"><i class="bi bi-check-all me-1"></i>Đã xử lý</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Trình Xem Ảnh Toàn Màn Hình -->
<div class="modal fade" id="imageViewerModal" tabindex="-1" aria-labelledby="imageViewerTitle" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content bg-dark">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title text-light fw-bold" id="imageViewerTitle">
                    <i class="bi bi-file-earmark-image"></i> Giấy tờ xe
                </h5>
                <div class="d-flex align-items-center">
                    <a id="downloadImageBtn" href="#" download class="btn btn-primary me-3 fw-bold rounded-pill px-4 shadow">
                        <i class="bi bi-download me-1"></i> Tải ảnh về
                    </a>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng tính năng xem" title="Đóng cửa sổ"></button>
                </div>
            </div>
            
            <div class="modal-body d-flex justify-content-center align-items-center position-relative overflow-hidden" id="imageContainer" style="cursor: grab;">
                <img id="fullSizeImage" src="" alt="View" style="max-height: 90vh; max-width: 90vw; object-fit: contain; transition: transform 0.15s ease-out; transform-origin: center center;" />
                
                <!-- Bảng điều khiển Zoom nổi -->
                <div class="position-absolute bottom-0 end-0 p-3 mb-3 me-3">
                    <div class="btn-group bg-white rounded-pill shadow-lg p-1">
                        <button type="button" class="btn btn-light rounded-circle ms-1" onclick="zoomImage(0.2)" title="Phóng to">
                            <i class="bi bi-zoom-in fs-5"></i>
                        </button>
                        <button type="button" class="btn btn-light rounded-circle mx-1" onclick="resetZoom()" title="Về mặc định">
                            <i class="bi bi-aspect-ratio fs-5"></i>
                        </button>
                        <button type="button" class="btn btn-light rounded-circle me-1" onclick="zoomImage(-0.2)" title="Thu nhỏ">
                            <i class="bi bi-zoom-out fs-5"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentScale = 1;
        const imageElement = document.getElementById('fullSizeImage');
        const container = document.getElementById('imageContainer');
        
        let isDragging = false;
        let startX, startY, translateX = 0, translateY = 0;

        function openImageViewer(imageUrl, title) {
            imageElement.src = imageUrl;
            
            // Xử lý link tải ảnh về
            const downloadBtn = document.getElementById('downloadImageBtn');
            downloadBtn.href = imageUrl;
            // Tách tên file từ URL để làm tên file tải về
            const fileName = imageUrl.substring(imageUrl.lastIndexOf('/') + 1);
            downloadBtn.setAttribute("download", fileName);
            
            document.getElementById('imageViewerTitle').innerHTML = `<i class="bi bi-file-earmark-image"></i> ${title}`;
            
            resetZoom();
            
            // Hiện Modal Bootstrap
            var imageModal = new bootstrap.Modal(document.getElementById('imageViewerModal'));
            imageModal.show();
        }

        function zoomImage(step) {
            currentScale += step;
            if(currentScale < 0.2) currentScale = 0.2;
            if(currentScale > 10) currentScale = 10;
            updateTransform();
        }

        function resetZoom() {
            currentScale = 1;
            translateX = 0;
            translateY = 0;
            updateTransform();
        }

        function updateTransform() {
            imageElement.style.transform = `translate(${translateX}px, ${translateY}px) scale(${currentScale})`;
        }

        // 1. Phóng to thu nhỏ bằng con lăn chuột (Scroll Wheel)
        container.addEventListener('wheel', function(e) {
            e.preventDefault(); // Chống cuộn trang ngầm
            if(e.deltaY < 0) {
                zoomImage(0.1); 
            } else {
                zoomImage(-0.1); 
            }
        }, { passive: false });

        // 2. Kéo thả ảnh khi đã zoom to (Pan / Drag)
        imageElement.addEventListener('mousedown', function(e) {
            e.preventDefault();
            isDragging = true;
            startX = e.clientX - translateX;
            startY = e.clientY - translateY;
            container.style.cursor = 'grabbing';
            imageElement.style.transition = 'none'; // Tắt hiệu ứng chuyển để kéo mượt
        });

        document.addEventListener('mouseup', function() {
            if (isDragging) {
                isDragging = false;
                container.style.cursor = 'grab';
                imageElement.style.transition = 'transform 0.15s ease-out';
            }
        });

        document.addEventListener('mousemove', function(e) {
            if (!isDragging) return;
            e.preventDefault();
            translateX = e.clientX - startX;
            translateY = e.clientY - startY;
            updateTransform();
        });
    </script>
}

<style>
    body { background-color: #f0f2f5; }
    .table th { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; }
</style>
@model IEnumerable<TimChuyenDi.Models.User>
@{
    ViewData["Title"] = "Quản lý Người dùng";
}

<div class="container-fluid py-4" style="max-width: 1200px;">
    <h3 class="fw-bold mb-4"><i class="bi bi-people-fill me-2"></i>Quản lý Người dùng</h3>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm"><i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <!-- Nơi tìm kiếm (Search) -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" class="row gx-2 gy-2 align-items-center">
                <div class="col-auto">
                    <label class="col-form-label fw-bold text-muted"><i class="bi bi-search me-1"></i>Tìm theo số điện thoại:</label>
                </div>
                <div class="col-md-4 col-sm-6">
                    <input type="text" name="searchPhone" class="form-control rounded-pill" value="@ViewBag.SearchPhone" placeholder="Nhập SĐT..." />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary rounded-pill fw-bold"><i class="bi bi-search me-1"></i>Tìm kiếm</button>
                    <a asp-action="Index" class="btn btn-light rounded-pill text-primary border"><i class="bi bi-arrow-clockwise me-1"></i>Làm mới</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Danh sách User -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-primary text-white rounded-top-4 py-3 d-flex justify-content-between align-items-center">
            <span class="fw-bold"><i class="bi bi-list-ul me-2"></i>Danh sách tài khoản hệ thống</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3 text-muted">ID</th>
                            <th>Họ và Tên</th>
                            <th>Số điện thoại</th>
                            <th>Email</th>
                            <th class="text-center">Vai trò</th>
                            <th>Ngày tạo</th>
                            <th class="text-center">Trạng thái</th>
                            <th>Lý do khóa</th>
                            <th class="text-center pe-3" style="width:130px">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3 text-muted small">#@item.UserId</td>
                                <td class="fw-semibold text-dark">@item.Name</td>
                                <td>@item.Phone</td>
                                <td class="text-muted">@(string.IsNullOrEmpty(item.Email) ? "—" : item.Email)</td>
                                <td class="text-center">
                                    @if (item.Role == 1)
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-2"><i class="bi bi-shield-lock me-1"></i>Admin</span>
                                    }
                                    else if (item.Role == 3)
                                    {
                                        <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 rounded-pill px-3 py-2 text-dark"><i class="bi bi-car-front me-1"></i>Tài xế</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2"><i class="bi bi-person me-1"></i>Khách hàng</span>
                                    }
                                </td>
                                <td class="text-muted small">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-center">
                                    @if (item.IsActive == true)
                                    {
                                        <span class="badge bg-primary rounded-pill px-3"><i class="bi bi-check-circle me-1"></i>Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3"><i class="bi bi-lock-fill me-1"></i>Đã khóa</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsActive != true && !string.IsNullOrEmpty(item.LockReason))
                                    {
                                        <span class="text-danger small"><i class="bi bi-exclamation-triangle me-1"></i>@item.LockReason</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-center pe-3">
                                    @if (item.UserId == 1)
                                    {
                                        <span class="text-muted small"><i class="bi bi-shield-fill-check text-warning me-1"></i>Bảo vệ</span>
                                    }
                                    else if (item.Role != 0)
                                    {
                                        @if (item.IsActive == true)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3" 
                                                    onclick="openLockModal(@item.UserId, '@item.Name')">
                                                <i class="bi bi-lock-fill"></i> Khóa
                                            </button>
                                        }
                                        else
                                        {
                                            <form asp-action="ToggleStatus" method="post" class="d-inline">
                                                <input type="hidden" name="userId" value="@item.UserId" />
                                                <button type="submit" class="btn btn-sm btn-success rounded-pill px-3" onclick="return confirm('Xác nhận mở khóa tài khoản này?');">
                                                    <i class="bi bi-unlock-fill"></i> Mở
                                                </button>
                                            </form>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Hệ thống</span>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr><td colspan="9" class="text-center py-4 text-muted">Không tìm thấy người dùng nào!</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Khóa Tài Khoản -->
<div class="modal fade" id="lockAccountModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="ToggleStatus" method="post" class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header bg-danger text-white rounded-top-4">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill me-2"></i>Khóa Tài Khoản</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">Thao tác khóa tài khoản của: <br/><strong id="lockUserName" class="text-danger fs-5"></strong></p>
                <input type="hidden" name="userId" id="lockUserId" value="" />
                
                <div class="mb-3">
                    <label for="lockReason" class="form-label fw-bold">Lý do khóa <span class="text-danger">*</span></label>
                    <textarea class="form-control rounded-3" id="lockReason" name="lockReason" rows="3" required placeholder="Nhập chi tiết lý do vi phạm..."></textarea>
                </div>
            </div>
            <div class="modal-footer border-top-0">
                <button type="button" class="btn btn-light rounded-pill" data-bs-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-danger rounded-pill fw-bold"><i class="bi bi-lock-fill me-1"></i>Xác nhận khóa</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openLockModal(userId, userName) {
            document.getElementById('lockUserId').value = userId;
            document.getElementById('lockUserName').innerText = userName;
            document.getElementById('lockReason').value = '';
            new bootstrap.Modal(document.getElementById('lockAccountModal')).show();
        }
    </script>
}

<style>
    body { background-color: #f0f2f5; }
    .table th { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; }
</style>
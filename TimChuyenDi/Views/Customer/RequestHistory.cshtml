@model IEnumerable<TimChuyenDi.Models.Shiprequest>
@{
    ViewData["Title"] = "Lịch sử Gửi hàng";
}

<style>
    .order-card {
        border-radius: 20px;
        border: none;
        background: white;
        transition: all 0.3s ease;
        margin-bottom: 20px;
        border: 1px solid #eef0f3;
    }
    .order-card:hover {
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        transform: translateY(-4px);
    }
    .status-dot {
        height: 8px;
        width: 8px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 6px;
    }
    .route-line {
        position: relative;
        padding-left: 20px;
        border-left: 2px dashed #dee2e6;
        margin: 10px 0 10px 10px;
    }
    .route-node {
        position: absolute;
        left: -6px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #fff;
        border: 2px solid;
    }
    .node-start { top: 0; border-color: #0d6efd; }
    .node-end { bottom: 0; border-color: #dc3545; }
    .cargo-pill {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 8px 12px;
        font-size: 0.85rem;
        color: #495057;
        border: 1px solid #e9ecef;
    }
</style>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark mb-0">
            <i class="bi bi-clock-history text-primary me-2"></i>Lịch sử yêu cầu
        </h3>
        <a asp-controller="Customer" asp-action="CreateRequest" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Gửi hàng ngay
        </a>
    </div>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="bg-light rounded-circle p-4 d-inline-block mb-3">
                    <i class="bi bi-folder2-open text-muted fs-1"></i>
                </div>
                <h5 class="text-muted">Bạn chưa có đơn hàng nào</h5>
                <p class="text-muted mb-4">Hãy tạo đơn hàng đầu tiên của bạn ngay hôm nay!</p>
                <a asp-controller="Customer" asp-action="CreateRequest" class="btn btn-outline-primary rounded-pill px-4">Bắt đầu ngay</a>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                var route = item.Shippingroutes.FirstOrDefault();
                var cargo = item.Cargodetails.FirstOrDefault();

                <div class="col-lg-6">
                    <div class="card order-card shadow-sm p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3 border-bottom pb-3">
                            <div>
                                <span class="badge bg-primary bg-opacity-10 text-primary fs-6 px-3 py-2 rounded-pill mb-2">#@(item.OrderCode ?? ("MD" + item.Id))</span>
                                <div class="text-muted small">
                                    <i class="bi bi-calendar3 me-1"></i> @item.PickupTimeFrom.ToString("dd/MM/yyyy")
                                    @if (item.PickupTimeTo.HasValue)
                                    {
                                        <span> - @item.PickupTimeTo.Value.ToString("dd/MM/yyyy")</span>
                                    }
                                </div>
                            </div>
                            <div>
                                @if (item.Status == 0) { <span class="badge bg-warning text-dark rounded-pill px-3 py-2"><i class="status-dot bg-dark"></i>Chờ xác nhận</span> }
                                else if (item.Status == 1) { <span class="badge bg-primary rounded-pill px-3 py-2"><i class="status-dot bg-white"></i>Đã xác nhận</span> }
                                else if (item.Status == 2) { <span class="badge bg-danger rounded-pill px-3 py-2"><i class="status-dot bg-white"></i>Bị từ chối</span> }
                                else if (item.Status == 3) { <span class="badge bg-info text-dark rounded-pill px-3 py-2"><i class="status-dot bg-dark"></i>Đang giao</span> }
                                else if (item.Status == 4) { <span class="badge bg-success rounded-pill px-3 py-2"><i class="status-dot bg-white"></i>Đã giao</span> }
                                else if (item.Status == 5) { <span class="badge bg-secondary rounded-pill px-3 py-2"><i class="status-dot bg-white"></i>Đã hủy</span> }
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <div class="route-line">
                                    <div class="route-node node-start"></div>
                                    <div class="small fw-bold text-dark mb-0">
                                        @if (route?.PickupType == 1) { 
                                            <span class="text-primary small d-block">Lấy tận nơi:</span>
                                            @route.PickupAddress
                                        } else {
                                            <span class="text-success small d-block">Trạm gửi: @(route?.FromStation?.StationName)</span>
                                            <span class="text-muted extra-small">@(route?.FromStation?.Address)</span>
                                        }
                                    </div>

                                    <div style="height: 20px;"></div>
                                    <div class="route-node node-end"></div>
                                    <div class="small fw-bold text-dark mb-0">
                                        @if (route?.DeliveryType == 1) {
                                            <span class="text-primary small d-block">Giao tận nơi:</span>
                                            @route.DeliveryAddress
                                        } else {
                                            <span class="text-success small d-block">Trạm nhận: @(route?.ToStation?.StationName)</span>
                                            <span class="text-muted extra-small">@(route?.ToStation?.Address)</span>
                                        }
                                    </div>

                                </div>
                            </div>

                            <div class="col-12 mb-3 d-flex flex-wrap gap-2">
                                <div class="cargo-pill">
                                    <i class="bi bi-box-seam me-1 text-primary"></i> @(cargo?.Description ?? "Kiện hàng")
                                </div>
                                <div class="cargo-pill">
                                    <i class="bi bi-speedometer2 me-1 text-danger"></i> @(cargo?.Weight ?? 0) kg
                                </div>
                                @if (cargo?.Length != null || cargo?.Width != null || cargo?.Height != null)
                                {
                                    <div class="cargo-pill">
                                        <i class="bi bi-aspect-ratio me-1 text-info"></i> @(cargo?.Length)x@(cargo?.Width)x@(cargo?.Height) cm
                                    </div>
                                }
                            </div>


                            <div class="col-12 mb-3 px-3 py-2 bg-light rounded-3 small border border-light-subtle">
                                <div class="row">
                                    <div class="col-6">
                                        <i class="bi bi-person-circle text-muted me-1"></i> @(route?.ReceiverName ?? "N/A")
                                    </div>
                                    <div class="col-6 text-end">
                                        <i class="bi bi-telephone text-muted me-1"></i> <span class="text-primary fw-bold">@(route?.ReceiverPhone ?? "N/A")</span>
                                    </div>
                                </div>
                            </div>


                            <div class="col-12 d-flex justify-content-between align-items-center">
                                <div class="fw-bold text-danger fs-5">
                                    @(item.TotalPrice.HasValue ? item.TotalPrice.Value.ToString("N0") : "0") <small>VNĐ</small>
                                </div>
                                <div class="d-flex gap-2">
                                    <a asp-action="RequestDetail" asp-controller="Customer" asp-route-id="@item.Id" class="btn btn-outline-primary rounded-pill btn-sm px-4">Chi tiết</a>
                                    
                                    @if (item.Status == 0)
                                    {
                                        <form asp-action="CancelRequest" method="post" class="d-inline">
                                            <input type="hidden" name="reqId" value="@item.Id" />
                                            <button type="submit" class="btn btn-outline-danger border-0 rounded-pill btn-sm px-3" onclick="return confirm('Hủy đơn hàng này?');">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                    else if (item.Status == 4)
                                    {
                                        <a asp-controller="Customer" asp-action="RateTrip" asp-route-reqId="@item.Id" class="btn btn-warning btn-sm rounded-pill px-3">Đánh giá</a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

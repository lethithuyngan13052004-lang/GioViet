@model IEnumerable<TimChuyenDi.Models.Trip>
@{
    ViewData["Title"] = "Tuyến xe đã lưu";
}

<h4 class="mt-4 mb-4"><i class="bi bi-bookmark-star-fill text-warning"></i> Các Chuyến Xe Bạn Đã Lưu</h4>

<div class="row">
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted mt-5">
            <p>Bạn chưa lưu chuyến xe nào. Hãy ra trang chủ để tìm và lưu tuyến nhé!</p>
        </div>
    }
    @foreach (var item in Model)
    {
        <div class="col-md-6 mb-3">
            <div class="card border-success h-100 shadow-sm">
                <div class="card-header bg-success text-white fw-bold">
                    @item.FromStationNavigation.Province <i class="bi bi-arrow-right"></i> @item.ToStationNavigation.Province
                </div>
                <div class="card-body">
                    <p class="mb-1"><strong>Tài xế:</strong> @item.Driver.Name</p>
                    <p class="mb-1"><strong>Biển số xe:</strong> @item.Vehicle.PlateNumber</p>
                    <p class="mb-1"><strong>Lịch trình:</strong> @item.StartTime.ToString("dd/MM/yyyy HH:mm")</p>
                    <p class="mb-0"><strong>Giá cước:</strong> <span class="text-success fw-bold">@item.BasePricePerKg.ToString("N0") VNĐ/kg</span></p>
                </div>
                <div class="card-footer bg-white text-end">
                    <a asp-controller="Customer" asp-action="BookTrip" asp-route-id="@item.TripId" class="btn btn-warning btn-sm">Gửi yêu cầu ghép hàng</a>
                </div>
            </div>
        </div>
    }
</div>
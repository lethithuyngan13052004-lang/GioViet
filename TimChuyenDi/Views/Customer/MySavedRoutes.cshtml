@model IEnumerable<TimChuyenDi.Models.Trip>
@{
    ViewData["Title"] = "Tuyến xe đã lưu";
}

<h4 class="mt-4 mb-4"><i class="bi bi-bookmark-star-fill text-warning"></i> Các Chuyến Xe Bạn Đã Lưu</h4>

<div class="row">
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted mt-5">
            <p>Bạn chưa lưu chuyến xe nào. Hãy ra trang chủ để tìm và lưu tuyến nhé!</p>
        </div>
    }
    @foreach (var item in Model)
    {
        <div class="col-md-6 mb-3">
            <div class="card border-0 h-100 shadow-sm rounded-4">
                <div class="card-header @(item.StartTime < DateTime.Now ? "bg-secondary" : "bg-primary") text-white fw-bold py-3 border-0 d-flex justify-content-between align-items-center" style="border-top-left-radius: 1rem; border-top-right-radius: 1rem;">
                    <span><i class="bi bi-geo-alt-fill me-1"></i> @(item.FromStationNavigation?.Province?.ProvinceName ?? "N/A") <i class="bi bi-arrow-right mx-1"></i> @(item.ToStationNavigation?.Province?.ProvinceName ?? "N/A")</span>
                    @if (item.StartTime < DateTime.Now)
                    {
                        <span class="badge bg-light text-dark fw-bold rounded-pill shadow-sm"><i class="bi bi-clock-history me-1"></i> Đã hoàn thành / Hết hạn</span>
                    }
                </div>
                <div class="card-body">
                    <p class="mb-1"><strong>Tài xế:</strong> @item.Driver.Name</p>
                    <p class="mb-1"><strong>Biển số xe:</strong> @item.Vehicle.PlateNumber - @(item.Vehicle?.VehicleType?.TypeName ?? "N/A")</p>
                    <p class="mb-1"><strong>Trạm đón:</strong> @(item.FromStationNavigation?.StationName ?? "N/A") - @(item.FromStationNavigation?.Address ?? ""), @(item.FromStationNavigation?.Province?.ProvinceName ?? "N/A")</p>
                    <p class="mb-1"><strong>Trạm trả:</strong> @(item.ToStationNavigation?.StationName ?? "N/A") - @(item.ToStationNavigation?.Address ?? ""), @(item.ToStationNavigation?.Province?.ProvinceName ?? "N/A")</p>
                    <p class="mb-0"><strong>Lịch trình:</strong> @item.StartTime.ToString("dd/MM/yyyy HH:mm")</p>
                    <div class="mt-3">
                        <button class="btn btn-sm btn-outline-info rounded-pill hover-scale" data-bs-toggle="modal" data-bs-target="#mapModal_@item.TripId">
                            <i class="bi bi-map me-1"></i> Xem lộ trình
                        </button>
                    </div>
                </div>
                <div class="card-footer bg-white text-end border-0 pb-3" style="border-bottom-left-radius: 1rem; border-bottom-right-radius: 1rem;">
                    @if (item.StartTime < DateTime.Now)
                    {
                        <button class="btn btn-secondary rounded-pill fw-medium shadow-sm disabled" disabled>
                            <i class="bi bi-slash-circle me-1"></i> Chuyến xe đã qua thời gian
                        </button>
                    }
                    else
                    {
                        <a asp-controller="Customer" asp-action="BookTrip" asp-route-id="@item.TripId" class="btn btn-primary rounded-pill fw-medium shadow-sm transition-all hover-scale">
                            <i class="bi bi-send me-1"></i> Gửi yêu cầu ghép hàng
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Map Modal for Trip @item.TripId -->
        <div class="modal fade" id="mapModal_@item.TripId" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 rounded-4 shadow-lg">
                    <div class="modal-header bg-primary text-white border-0" style="border-top-left-radius: 1rem; border-top-right-radius: 1rem;">
                        <h5 class="modal-title fw-bold"><i class="bi bi-map me-2"></i> Lộ trình dự kiến</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-0">
                        <div id="routeMap_@item.TripId" style="height: 400px; width: 100%; border-bottom-left-radius: 1rem; border-bottom-right-radius: 1rem;"></div>
                    </div>
                </div>
            </div>
        </div>

    }
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var maps = {};
        
        @foreach(var item in Model) {
        <text>
        var modal_@(item.TripId) = document.getElementById('mapModal_@item.TripId');
        if(modal_@(item.TripId)) {
            modal_@(item.TripId).addEventListener('shown.bs.modal', function () {
                if (!maps[@item.TripId]) {
                    var map = L.map('routeMap_@item.TripId');
                    maps[@item.TripId] = map;
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        attribution: '&copy; OpenStreetMap'
                    }).addTo(map);

                    var fromLat = @(item.FromStationNavigation?.Latitude?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "21.028511");
                    var fromLng = @(item.FromStationNavigation?.Longitude?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "105.804817");
                    var toLat = @(item.ToStationNavigation?.Latitude?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "10.823099");
                    var toLng = @(item.ToStationNavigation?.Longitude?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "106.629662");

                    var fromMarker = L.marker([fromLat, fromLng], {
                        icon: L.icon({ iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-blue.png', iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34] })
                    }).addTo(map).bindPopup(`<b>Trạm đón:</b><br/>@Html.Raw(item.FromStationNavigation?.StationName ?? "")`);
                    
                    var toMarker = L.marker([toLat, toLng], {
                        icon: L.icon({ iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-red.png', iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34] })
                    }).addTo(map).bindPopup(`<b>Trạm trả:</b><br/>@Html.Raw(item.ToStationNavigation?.StationName ?? "")`);

                    var latlngs = [
                        [fromLat, fromLng],
                        [toLat, toLng]
                    ];
                    var polyline = L.polyline(latlngs, {color: '#0d6efd', weight: 4, opacity: 0.8, dashArray: '10, 10'}).addTo(map);
                    map.fitBounds(polyline.getBounds(), { padding: [50, 50] });
                }
            });
        }
        </text>
        }
    });
</script>
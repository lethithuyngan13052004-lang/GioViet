@model TimChuyenDi.Models.Shiprequest

@{
    ViewData["Title"] = "Chi tiết đơn hàng " + (Model.OrderCode ?? ("#MD" + Model.Id));




    // Xử lý màu sắc trạng thái
    string badgeClass = Model.Status switch
    {
        0 => "bg-warning text-dark",
        1 => "bg-info text-dark",
        2 => "bg-danger",
        3 => "bg-primary",
        4 => "bg-success",
        _ => "bg-dark"
    };
    string statusText = Model.Status switch
    {
        0 => "⏳ Chờ xác nhận",
        1 => "✅ Đã xác nhận",
        2 => "❌ Bị từ chối",
        3 => "🚚 Đang giao hàng",
        4 => "🎉 Đã giao thành công",
        _ => "⛔ Đã hủy"
    };
    
    // Sắp xếp các điểm dừng theo StopOrder
    var tripStations = Model.Trip?.TripStations?.OrderBy(ts => ts.StopOrder).ToList() ?? new List<TimChuyenDi.Models.TripStation>();
}

<!-- Leaflet & Routing Assets -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.css" />
<style>
    .timeline-container { position: relative; padding-left: 20px; border-left: 2px dashed #dee2e6; margin-left: 10px; }
    .timeline-item { position: relative; margin-bottom: 25px; }
    .timeline-item:last-child { margin-bottom: 0; }
    .timeline-dot { position: absolute; left: -26px; top: 0; width: 12px; height: 12px; border-radius: 50%; background: #dee2e6; border: 2px solid white; z-index: 1; }
    .timeline-dot.active { background: #0d6efd; box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.2); }
    .timeline-dot.start { background: #198754; }
    .timeline-dot.end { background: #dc3545; }
    .timeline-content { background: white; border-radius: 8px; padding: 0 0 0 10px; }
    .timeline-content h6 { margin: 0; font-size: 0.9rem; font-weight: 700; color: #212529; }
    .timeline-content p { margin: 0; font-size: 0.75rem; color: #6c757d; }
    #map { height: 400px; border-radius: 16px; border: 1px solid rgba(0,0,0,0.08); box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
</style>

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary"><i class="bi bi-receipt-cutoff me-2"></i>Chi tiết đơn hàng @(Model.OrderCode ?? ("#MD" + Model.Id))</h3>



        <a asp-action="RequestHistory" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="card shadow border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-light p-4 border-bottom-0 d-flex justify-content-between align-items-center">
            <div>
                <span class="text-muted d-block small">Thời gian lấy hàng: </span>
                <span class="fw-bold">@Model.PickupTimeFrom.ToString("dd/MM/yyyy")</span>
                @if (Model.PickupTimeTo.HasValue)
                {
                    <span class="text-muted"> - </span>
                    <span class="fw-bold">@Model.PickupTimeTo.Value.ToString("dd/MM/yyyy")</span>
                }
            </div>

            <span class="badge @badgeClass fs-5 px-4 py-2 rounded-pill shadow-sm">@statusText</span>
        </div>

        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-md-7">
                    <h5 class="fw-bold border-bottom pb-2 mb-3"><i class="bi bi-box-seam text-primary me-2"></i>Thông tin vận chuyển</h5>

                    <div class="mb-3">
                        @{ var r1 = Model.Shippingroutes.FirstOrDefault(); }
                        <label class="text-muted fw-bold small">📍 ĐỊA CHỈ LẤY HÀNG @(Model.Trip != null ? $"({Model.Trip.FromStationNavigation.Province.ProvinceName})" : "")</label>
                        <div class="d-flex align-items-center">
                            <span class="badge bg-secondary me-2">@(r1?.PickupType == 1 ? "Lấy tận nơi" : "Gửi tại trạm")</span>
                            <div>
                                <p class="fs-6 fw-bold mb-0">@(!string.IsNullOrEmpty(r1?.PickupAddress) ? r1.PickupAddress : (r1?.FromStation?.StationName ?? "Nơi lấy hàng"))</p>
                                @if (r1?.PickupType == 2 && r1?.FromStation != null)
                                {
                                    <small class="text-muted">@r1.FromStation.Address</small>
                                }
                            </div>
                        </div>

                    </div>


                    <div class="mb-3">
                        @{ var r2 = Model.Shippingroutes.FirstOrDefault(); }
                        <label class="text-muted fw-bold small">🚩 ĐỊA CHỈ GIAO HÀNG @(Model.Trip != null ? $"({Model.Trip.ToStationNavigation.Province.ProvinceName})" : "")</label>
                        <div class="d-flex align-items-center">
                            <span class="badge bg-secondary me-2">@(r2?.DeliveryType == 1 ? "Giao tận nơi" : "Nhận tại trạm")</span>
                            <div>
                                <p class="fs-6 fw-bold mb-0">@(!string.IsNullOrEmpty(r2?.DeliveryAddress) ? r2.DeliveryAddress : (r2?.ToStation?.StationName ?? "Nơi giao hàng"))</p>
                                @if (r2?.DeliveryType == 2 && r2?.ToStation != null)
                                {
                                    <small class="text-muted">@r2.ToStation.Address</small>
                                }
                            </div>
                        </div>

                    </div>


                    <div class="mb-3 bg-light p-3 rounded-3">
                        <label class="text-muted fw-bold small">👤 NGƯỜI NHẬN</label>
                        <p class="fs-6 fw-bold text-dark mb-1">@(Model.Shippingroutes.FirstOrDefault()?.ReceiverName)</p>
                        <p class="fs-6 text-primary mb-0 fw-bold"><i class="bi bi-telephone-fill me-1"></i> @(Model.Shippingroutes.FirstOrDefault()?.ReceiverPhone)</p>
                    </div>


                    @if (!string.IsNullOrEmpty(Model.Cargodetails.FirstOrDefault()?.Description))
                    {
                        <div class="alert alert-warning border-0 shadow-sm mt-3">
                            <i class="bi bi-journal-text me-2"></i><strong>Ghi chú:</strong> @(Model.Cargodetails.FirstOrDefault()?.Description)
                        </div>
                    }
                </div>

                <div class="col-md-5 border-start">
                    <h5 class="fw-bold border-bottom pb-2 mb-3"><i class="bi bi-truck text-success me-2"></i>Thông tin chuyến xe</h5>

                    @if (Model.Trip != null)
                    {
                        <ul class="list-group list-group-flush mb-3">
                            <li class="list-group-item bg-transparent px-0 d-flex justify-content-between">
                                <span class="text-muted small">Tài xế:</span>
                                <span class="fw-bold">@Model.Trip.Driver.Name</span>
                            </li>
                            <li class="list-group-item bg-transparent px-0 d-flex justify-content-between">
                                <span class="text-muted small">Biển số xe:</span>
                                <span class="badge bg-secondary fs-6 rounded-pill">@Model.Trip.Vehicle.PlateNumber</span>
                            </li>
                            <li class="list-group-item bg-transparent px-0 d-flex justify-content-between">
                                <span class="text-muted small">Khối lượng gửi:</span>
                                <span class="fw-bold text-dark">@(Model.Cargodetails.FirstOrDefault()?.Weight) kg</span>
                            </li>

                        </ul>

                        <h5 class="fw-bold border-bottom pb-2 mb-3 mt-4"><i class="bi bi-geo-alt text-danger me-2"></i>Lộ trình xe chạy</h5>

                        
                        <div class="timeline-container mt-3">
                            <!-- Xuất phát -->
                            <div class="timeline-item">
                                <div class="timeline-dot start active"></div>
                                <div class="timeline-content">
                                    <h6>@Model.Trip.FromStationNavigation.StationName</h6>
                                    <p class="mb-0 text-success small">Xuất phát lúc @Model.Trip.StartTime.ToString("HH:mm dd/MM")</p>
                                    <p>@Model.Trip.FromStationNavigation.Address</p>
                                </div>
                            </div>

                            <!-- Các trạm dừng -->
                            @foreach (var ts in tripStations)
                            {
                                <div class="timeline-item">
                                    <div class="timeline-dot active"></div>
                                    <div class="timeline-content">
                                        <h6>@ts.Station.StationName</h6>
                                        @if (ts.EstArrivalTime.HasValue)
                                        {
                                            <p class="mb-0 small">Dự kiến đến: @ts.EstArrivalTime.Value.ToString("HH:mm dd/MM")</p>
                                        }
                                        <p>@ts.Station.Address</p>
                                    </div>
                                </div>
                            }

                            <!-- Trạm cuối -->
                            <div class="timeline-item">
                                <div class="timeline-dot end active"></div>
                                <div class="timeline-content">
                                    <h6>@Model.Trip.ToStationNavigation.StationName</h6>
                                    @if (Model.Trip.ArrivalTime.HasValue)
                                    {
                                        <p class="mb-0 text-danger small">Kết thúc lúc @Model.Trip.ArrivalTime.Value.ToString("HH:mm dd/MM")</p>
                                    }
                                    <p>@Model.Trip.ToStationNavigation.Address</p>
                                </div>
                            </div>
                        </div>


                        <div class="alert alert-primary border-0 shadow-sm mt-4 p-3 rounded-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-white rounded-circle p-2 me-3 shadow-sm">
                                    <i class="bi bi-info-circle text-primary fs-4"></i>
                                </div>
                                <p class="mb-0 small">Đơn hàng của bạn sẽ được tài xế sắp xếp lộ trình tối ưu nhất dựa trên các điểm dừng trên.</p>
                            </div>
                        </div>

                        <!-- Map View Section -->
                        <div class="mt-4 pt-4 border-top">
                            <h5 class="fw-bold mb-3"><i class="bi bi-map-fill text-primary me-2"></i>Bản đồ lộ trình chuyến xe</h5>
                            <div class="card border-0 shadow-sm rounded-4 overflow-hidden position-relative">
                                <div id="map"></div>
                                <div class="position-absolute bottom-0 start-0 p-3 w-100" style="z-index: 1000; pointer-events: none;">
                                    <div class="bg-white p-3 rounded-pill shadow-lg d-flex justify-content-center align-items-center mx-auto" style="max-width: 400px; pointer-events: auto;">
                                        <div class="text-center px-4">
                                            <span class="d-block small text-muted">Khoảng cách</span>
                                            <span class="h5 fw-bold mb-0 text-primary" id="totalDistance">-- km</span>
                                        </div>
                                        <div class="vr"></div>
                                        <div class="text-center px-4">
                                            <span class="d-block small text-muted">Thời gian</span>
                                            <span class="h5 fw-bold mb-0 text-success" id="totalTime">-- h</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">

                            <div class="bg-light rounded-circle d-inline-block p-3 mb-3">
                                <i class="bi bi-search fs-2 text-muted"></i>
                            </div>
                            <p class="text-muted small">Đơn hàng hiện chưa có chuyến xe cố định.<br/>Tài xế sẽ sớm liên hệ xác nhận với bạn.</p>
                        </div>
                    }

                    <div class="bg-primary bg-opacity-10 p-4 rounded-4 text-center border border-primary border-opacity-25">
                        <span class="text-muted fw-bold d-block mb-1">TỔNG CƯỚC PHÍ (DỰ KIẾN)</span>
                        <h2 class="fw-bold text-primary mb-0">@(Model.TotalPrice.HasValue ? Model.TotalPrice.Value.ToString("N0") : "Chờ báo giá") <span class="fs-5">VNĐ</span></h2>
                    </div>

                    @if (Model.Status == 0)
                    {
                        <form asp-action="CancelRequest" asp-controller="Customer" method="post" class="mt-4 d-grid">
                            <input type="hidden" name="reqId" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này?');">
                                <i class="bi bi-x-circle me-1"></i> Hủy đơn hàng này
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.js"></script>

<script>
    var map;
    var routingControl;
    
    $(document).ready(function () {
        @if (Model.Trip != null) {
            <text>initMapView();</text>
        }
    });

    function initMapView() {
        map = L.map('map').setView([16.0544, 108.2022], 6);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

        routingControl = L.Routing.control({
            waypoints: [],
            routeWhileDragging: false,
            addWaypoints: false,      // User cannot add points
            draggableWaypoints: false,// Prevents dragging
            show: false,
            fitSelectedRoutes: false, // We fit bounds manually
            router: L.Routing.osrmv1({ 
                serviceUrl: 'https://router.project-osrm.org/route/v1', 
                profile: 'driving' 
            }),
            lineOptions: { styles: [{ color: '#36b9cc', opacity: 0.8, weight: 6 }] },
            createMarker: () => null
        }).addTo(map);

        routingControl.on('routesfound', function (e) {
            var route = e.routes[0];
            var summary = route.summary;
            $('#totalDistance').text((summary.totalDistance / 1000).toFixed(1) + " km");
            $('#totalTime').text((summary.totalTime / 3600).toFixed(1) + " h");
        });

        routingControl.on('routingerror', function (e) {
            console.error("OSRM Routing Error:", e);
            // Draw a dashed straight line indicating failure
            $('#totalDistance').text("Lỗi dẫn đường");
            $('#totalTime').text("--");
            alert("Hệ thống bản đồ (OSRM) đang quá tải hoặc các điểm dừng nằm ngoài mạng lưới đường bộ. Đang hiển thị đường thẳng nối các trạm.");
        });

        const VN_CORRIDOR = [
            { name: "Hà Tĩnh (AH1)", lat: 18.06, lng: 106.31 },
            { name: "Quảng Ngãi (AH1)", lat: 15.12, lng: 108.79 },
            { name: "Phú Yên (AH1)", lat: 13.10, lng: 109.28 },
            { name: "Ninh Thuận (AH1)", lat: 11.58, lng: 108.98 }
        ];

        const VN_REGIONS = {
            'North': ["Hà Nội", "Hải Phòng", "Hải Dương", "Hưng Yên", "Bắc Ninh", "Vĩnh Phúc", "Thái Nguyên", "Phú Thọ", "Bắc Giang", "Quảng Ninh", "Bắc Kạn", "Cao Bằng", "Hà Giang", "Lạng Sơn", "Tuyên Quang", "Lào Cai", "Yên Bái", "Điện Biên", "Hòa Bình", "Lai Châu", "Sơn La", "Hà Nam", "Nam Định", "Ninh Bình", "Thái Bình"],
            'Central': ["Thanh Hóa", "Nghệ An", "Hà Tĩnh", "Quảng Bình", "Quảng Trị", "Thừa Thiên Huế", "Đà Nẵng", "Quảng Nam", "Quảng Ngãi", "Bình Định", "Phú Yên", "Khánh Hòa", "Ninh Thuận", "Bình Thuận", "Kon Tum", "Gia Lai", "Đắk Lắk", "Đắk Nông", "Lâm Đồng"],
            'South': ["Hồ Chí Minh", "Bình Dương", "Đồng Nai", "Bình Phước", "Tây Ninh", "Bà Rịa - Vũng Tàu", "Long An", "Tiền Giang", "Bến Tre", "Trà Vinh", "Vĩnh Long", "Đồng Tháp", "An Giang", "Kiên Giang", "Cần Thơ", "Hậu Giang", "Sóc Trăng", "Bạc Liêu", "Cà Mau"]
        };

        function getRegion(provinceName) {
            if (!provinceName) return null;
            for (let region in VN_REGIONS) {
                if (VN_REGIONS[region].some(p => provinceName.includes(p) || p.includes(provinceName))) return region;
            }
            return null;
        }

        function sortRawWaypoints(start, end, stops) {
            if (stops.length <= 1) return stops;
            const vecAB = { lat: end.lat - start.lat, lng: end.lng - start.lng };
            return stops.sort((a, b) => {
                const projA = (a.lat - start.lat) * vecAB.lat + (a.lng - start.lng) * vecAB.lng;
                const projB = (b.lat - start.lat) * vecAB.lat + (b.lng - start.lng) * vecAB.lng;
                return projA - projB;
            });
        }

        var markers = L.layerGroup().addTo(map);

        const iconBase = "https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-";
        const shadowUrl = "https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png";
        const createIcon = (color) => L.icon({
            iconUrl: iconBase + color + ".png", shadowUrl: shadowUrl,
            iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34], shadowSize: [41, 41]
        });

        var startPoint = null, endPoint = null;
        var intermediateStops = [];

        @if (Model.Trip?.FromStationNavigation != null)
        {
            <text>
            var sLat = @((Model.Trip.FromStationNavigation.Latitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture));
            var sLng = @((Model.Trip.FromStationNavigation.Longitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture));
            if (sLat && sLng) {
                startPoint = { lat: sLat, lng: sLng, icon: createIcon('blue'), name: '<b>Bắt đầu:</b> @Html.Raw(Model.Trip.FromStationNavigation.StationName)', province: '@Html.Raw(Model.Trip.FromStationNavigation.Province?.ProvinceName ?? "")' };
            }
            </text>
        }

        @if (Model.Trip?.TripStations != null)
        {
            foreach (var ts in Model.Trip.TripStations.OrderBy(x => x.StopOrder))
            {
                if (ts.Station != null)
                {
                    <text>
                    var iLat = @((ts.Station.Latitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture));
                    var iLng = @((ts.Station.Longitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture));
                    if (iLat && iLng) {
                        intermediateStops.push({ lat: iLat, lng: iLng, icon: createIcon('orange'), name: '<b>Trạm đi qua:</b> @Html.Raw(ts.Station.StationName)', province: '@Html.Raw(ts.Station.Province?.ProvinceName ?? "")' });
                    }
                    </text>
                }
            }
        }

        @if (Model.Trip?.ToStationNavigation != null)
        {
            <text>
            var eLat = @((Model.Trip.ToStationNavigation.Latitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture));
            var eLng = @((Model.Trip.ToStationNavigation.Longitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture));
            if (eLat && eLng) {
                endPoint = { lat: eLat, lng: eLng, icon: createIcon('green'), name: '<b>Kết thúc:</b> @Html.Raw(Model.Trip.ToStationNavigation.StationName)', province: '@Html.Raw(Model.Trip.ToStationNavigation.Province?.ProvinceName ?? "")' };
            }
            </text>
        }

        // Apply geographic sorting
        if (startPoint && endPoint && intermediateStops.length > 0) {
            intermediateStops = sortRawWaypoints(startPoint, endPoint, intermediateStops);
        }

        var rawWaypoints = [];
        if (startPoint) rawWaypoints.push(startPoint);
        intermediateStops.forEach(s => rawWaypoints.push(s));
        if (endPoint) rawWaypoints.push(endPoint);

        var startRegion = startPoint ? getRegion(startPoint.province) : null;
        var endRegion = endPoint ? getRegion(endPoint.province) : null;
        var sameRegion = (startRegion && endRegion && startRegion === endRegion);
        var isShortCrossRegion = false;
        
        if (startRegion && endRegion && !sameRegion) {
            if ((startRegion === 'Central' && (endRegion === 'North' || endRegion === 'South')) ||
                (endRegion === 'Central' && (startRegion === 'North' || startRegion === 'South'))) {
                isShortCrossRegion = true;
            }
        }

        var finalWaypoints = [];
        for (var i = 0; i < rawWaypoints.length; i++) {
            var curr = rawWaypoints[i];
            var latLng = L.latLng(curr.lat, curr.lng);
            L.marker(latLng, { icon: curr.icon }).addTo(markers).bindPopup(curr.name);
            finalWaypoints.push(latLng);

            if (i < rawWaypoints.length - 1 && !sameRegion) {
                var next = rawWaypoints[i+1];
                var latDiff = Math.abs(curr.lat - next.lat);
                var crossesWaist = (Math.min(curr.lat, next.lat) < 16.5 && Math.max(curr.lat, next.lat) > 19.5);
                
                if (latDiff > 2.5 || crossesWaist) { 
                    var minLat = Math.min(curr.lat, next.lat);
                    var maxLat = Math.max(curr.lat, next.lat);
                    var isNorthbound = (next.lat > curr.lat);
                    var applicablePoints = VN_CORRIDOR.filter(cp => cp.lat > minLat + 0.5 && cp.lat < maxLat - 0.5);
                    
                    if (isNorthbound) applicablePoints.sort((a,b) => a.lat - b.lat);
                    else applicablePoints.sort((a,b) => b.lat - a.lat);
                    
                    var maxAnchors = isShortCrossRegion ? 1 : 2;
                    if (applicablePoints.length > maxAnchors) {
                        if (maxAnchors === 1) applicablePoints = [applicablePoints[Math.floor(applicablePoints.length / 2)]];
                        else applicablePoints = [applicablePoints[0], applicablePoints[applicablePoints.length - 1]];
                    }
                    applicablePoints.forEach(cp => {
                        finalWaypoints.push(L.latLng(cp.lat, cp.lng));
                    });
                }
            }
        }

        if (finalWaypoints.length >= 2) {
            routingControl.setWaypoints(finalWaypoints);
            setTimeout(() => {
                var group = new L.featureGroup(rawWaypoints.map(w => L.marker([w.lat, w.lng])));
                map.fitBounds(group.getBounds().pad(0.2));
            }, 500);
        }
    }
</script>
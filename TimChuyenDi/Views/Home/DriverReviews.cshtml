@model IEnumerable<TimChuyenDi.Models.Rating>
@{
    ViewData["Title"] = "Đánh giá Tài xế " + ViewBag.DriverName;
}

<div class="mt-4 mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3"><i class="bi bi-arrow-left"></i> Quay lại tìm chuyến</a>

    <div class="card shadow-sm border-0 bg-light">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h4 class="text-primary mb-1"><i class="bi bi-person-badge"></i> Hồ sơ Tài xế: @ViewBag.DriverName</h4>
                <p class="text-muted mb-0">Hệ thống ghi nhận đánh giá minh bạch từ những khách hàng đã sử dụng dịch vụ.</p>
            </div>
            <div class="text-end">
                <span class="fs-4 fw-bold text-danger">@ViewBag.AverageScore / 5 ⭐</span><br />
                <small class="text-muted">(@ViewBag.TotalReviews lượt đánh giá)</small>
            </div>
        </div>
    </div>
</div>

<div class="row">
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted mt-5">
            <p>Tài xế này hiện chưa có bài đánh giá nào.</p>
        </div>
    }

    @foreach (var item in Model)
    {
        <div class="col-md-6 mb-3">
            <div class="card shadow-sm h-100 border-0 border-start border-primary border-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <h6 class="fw-bold mb-1">
                            @(item.Customer.Name.Length > 2 ? item.Customer.Name.Substring(0, item.Customer.Name.Length - 2) + "**" : item.Customer.Name)
                        </h6>
                        <div class="text-warning">
                            @for (int i = 0; i < item.Score; i++)
                            {
                                <span>⭐</span>
                            }
                        </div>
                    </div>
                    <p class="small text-muted mb-2">
                        Tuyến:
                        @item.Req.Trip.FromStationNavigation.Province.ProvinceName
                        ➔
                        @item.Req.Trip.ToStationNavigation.Province.ProvinceName
                    </p>
                    <p class="mb-0 text-dark">"@item.Comment"</p>
                </div>
            </div>
        </div>
    }
</div>
@model TimChuyenDi.Models.Trip
@{
    ViewData["Title"] = "Chi Tiết Chuyến Đi - Gió Việt";
}

<style>
    .trip-detail-card {
        border-radius: 20px;
        border: none;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        background: #fff;
        overflow: hidden;
    }
    .trip-detail-header {
        background-color: #0d6efd;
        color: white;
        padding: 16px 20px;
        font-weight: 600;
        font-size: 1.1rem;
    }
    .user-avatar-placeholder {
        width: 45px;
        height: 45px;
        background-color: #f1f5f9;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .badge-route {
        background-color: #e6f6ec;
        color: #15803d;
        border-radius: 30px;
        padding: 4px 12px;
        font-size: 0.85rem;
        font-weight: 600;
        border: 1px solid #16a34a;
    }
    .capacity-badge-kg {
        background-color: #e0f2fe;
        color: #0284c7;
        padding: 6px 16px;
        border-radius: 30px;
        font-weight: 600;
        font-size: 0.95rem;
    }

    .info-line {
        display: flex;
        align-items: flex-start;
        margin-bottom: 12px;
    }
    .info-line i {
        margin-top: 3px;
        margin-right: 12px;
        font-size: 1.1rem;
    }
    .info-text {
        font-size: 1.05rem;
        color: #334155;
    }
</style>

<div class="container py-5">
    
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            
            <a href="javascript:history.back()" class="text-decoration-none text-muted mb-3 d-inline-block hover-scale">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>

            <div class="trip-detail-card animate__animated animate__fadeInUp">
                <!-- Header -->
                <div class="trip-detail-header text-center">
                    @(Model.FromStationNavigation?.Province?.ProvinceName) <i class="bi bi-arrow-right mx-2"></i> @(Model.ToStationNavigation?.Province?.ProvinceName)
                </div>

                <!-- Body -->
                <div class="p-4">
                    <!-- Driver Info -->
                    <div class="d-flex align-items-center mb-4">
                        <div class="user-avatar-placeholder me-3">
                            <i class="bi bi-person-fill text-secondary fs-4"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-bold text-dark" style="font-size: 1.1rem;">@Model.Driver.Name</div>
                            @if (ViewBag.AvgScore > 0)
                            {
                                <div class="text-warning small text-nowrap mt-1">
                                    @for(int i = 1; i <= 5; i++)
                                    {
                                        if (i <= Math.Round(ViewBag.AvgScore)) { <i class="bi bi-star-fill"></i> }
                                        else { <i class="bi bi-star"></i> }
                                    }
                                    <span class="text-muted ms-1">(@ViewBag.ReviewCount đánh giá)</span>
                                </div>
                            }
                            else
                            {
                                <div class="text-muted small mt-1">Chưa có đánh giá</div>
                            }
                        </div>
                        <div>
                            <span class="badge-route">
                                <i class="bi @(Model.RouteType == 1 ? "bi-record-circle" : "bi-bezier2") me-1"></i>
                                @(Model.RouteTypeNavigation?.Type ?? (Model.RouteType == 1 ? "Direct" : "Multi-stop"))
                            </span>
                        </div>
                    </div>

                    <hr class="opacity-10 mb-4" />

                    <!-- Route Details -->
                    <div class="info-line">
                        <i class="bi bi-geo-alt text-primary"></i>
                        <div class="info-text">Trạm @(Model.FromStationNavigation?.StationName) - @(Model.FromStationNavigation?.Address), @(Model.FromStationNavigation?.Province?.ProvinceName)</div>
                    </div>
                    <div class="info-line">
                        <i class="bi bi-flag text-danger"></i>
                        <div class="info-text">Trạm @(Model.ToStationNavigation?.StationName) - @(Model.ToStationNavigation?.Address), @(Model.ToStationNavigation?.Province?.ProvinceName)</div>
                    </div>
                    
                    <div class="text-center mt-3 mb-4">
                        <button class="btn btn-sm btn-outline-primary rounded-pill px-4 hover-scale shadow-sm fw-bold" data-bs-toggle="modal" data-bs-target="#routeMapModal">
                            <i class="bi bi-map me-1"></i> Xem lộ trình trên bản đồ
                        </button>
                    </div>
                    <div class="info-line">
                        <i class="bi bi-calendar-event text-secondary"></i>
                        <div class="info-text">@Model.StartTime.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    <div class="info-line">
                        <i class="bi bi-truck text-success"></i>
                        <div class="info-text">Loại xe: <strong>@(Model.Vehicle?.VehicleType?.TypeName ?? "N/A")</strong></div>
                    </div>
                    <div class="info-line mb-4">
                        <i class="bi bi-car-front-fill text-muted"></i>
                        <div class="info-text">Biển số xe: <strong>@(Model.Vehicle?.PlateNumber)</strong></div>
                    </div>

                    <!-- Capacity Badges -->
                    <div class="d-flex flex-wrap gap-3 mb-4">
                        <div class="capacity-badge-kg">
                            <span class="fw-bold">@Model.AvaiCapacityKg</span> kg
                        </div>
                    </div>

                    <hr class="opacity-10 mb-0" />
                </div>

                <!-- Footer (Actions) -->
                <div class="bg-white p-3 pt-0 pb-4 px-4 border-0">
                    <div class="row g-3">
                        <div class="col-3">
                            <a asp-controller="Customer" asp-action="SaveRoute" asp-route-id="@Model.TripId" class="btn btn-outline-secondary w-100 rounded-pill py-3 hover-scale border-1 shadow-sm h-100 d-flex align-items-center justify-content-center">
                                <i class="bi bi-bookmark fs-5"></i>
                            </a>
                        </div>
                        <div class="col-9">
                            <a asp-controller="Customer" asp-action="BookTrip" asp-route-id="@Model.TripId" class="btn btn-primary w-100 rounded-pill py-3 fw-bold fs-5 shadow-sm hover-scale text-uppercase d-flex align-items-center justify-content-center h-100">
                                GỬI YÊU CẦU
                            </a>
                        </div>
                    </div>
                </div>
            </div>

<!-- Map Modal -->
<div class="modal fade" id="routeMapModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header bg-primary text-white border-0" style="border-top-left-radius: 1rem; border-top-right-radius: 1rem;">
                <h5 class="modal-title fw-bold"><i class="bi bi-map me-2"></i> Lộ trình dự kiến</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div id="routeMap" style="height: 450px; width: 100%; border-bottom-left-radius: 1rem; border-bottom-right-radius: 1rem;"></div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var map;
        var routingControl;
        var mapModal = document.getElementById('routeMapModal');
        
        mapModal.addEventListener('shown.bs.modal', function () {
            if (!map) {
                map = L.map('routeMap').setView([16.0544, 108.2022], 6);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; OpenStreetMap'
                }).addTo(map);

                routingControl = L.Routing.control({
                    waypoints: [],
                    routeWhileDragging: false,
                    addWaypoints: false,      
                    draggableWaypoints: false,
                    show: false,
                    fitSelectedRoutes: false, 
                    router: L.Routing.osrmv1({ 
                        serviceUrl: 'https://router.project-osrm.org/route/v1', 
                        profile: 'driving' 
                    }),
                    lineOptions: { styles: [{ color: '#0d6efd', opacity: 0.8, weight: 6 }] },
                    createMarker: () => null
                }).addTo(map);

                routingControl.on('routingerror', function (e) {
                    console.error("OSRM Routing Error:", e);
                    alert("Hệ thống bản đồ đang tải hoặc các điểm dừng nằm ngoài mạng lưới. Đang hiển thị đường thẳng nối các trạm.");
                });

                const VN_CORRIDOR = [
                    { name: "Hà Tĩnh (AH1)", lat: 18.06, lng: 106.31 },
                    { name: "Quảng Ngãi (AH1)", lat: 15.12, lng: 108.79 },
                    { name: "Phú Yên (AH1)", lat: 13.10, lng: 109.28 },
                    { name: "Ninh Thuận (AH1)", lat: 11.58, lng: 108.98 }
                ];

                const VN_REGIONS = {
                    'North': ["Hà Nội", "Hải Phòng", "Hải Dương", "Hưng Yên", "Bắc Ninh", "Vĩnh Phúc", "Thái Nguyên", "Phú Thọ", "Bắc Giang", "Quảng Ninh", "Bắc Kạn", "Cao Bằng", "Hà Giang", "Lạng Sơn", "Tuyên Quang", "Lào Cai", "Yên Bái", "Điện Biên", "Hòa Bình", "Lai Châu", "Sơn La", "Hà Nam", "Nam Định", "Ninh Bình", "Thái Bình"],
                    'Central': ["Thanh Hóa", "Nghệ An", "Hà Tĩnh", "Quảng Bình", "Quảng Trị", "Thừa Thiên Huế", "Đà Nẵng", "Quảng Nam", "Quảng Ngãi", "Bình Định", "Phú Yên", "Khánh Hòa", "Ninh Thuận", "Bình Thuận", "Kon Tum", "Gia Lai", "Đắk Lắk", "Đắk Nông", "Lâm Đồng"],
                    'South': ["Hồ Chí Minh", "Bình Dương", "Đồng Nai", "Bình Phước", "Tây Ninh", "Bà Rịa - Vũng Tàu", "Long An", "Tiền Giang", "Bến Tre", "Trà Vinh", "Vĩnh Long", "Đồng Tháp", "An Giang", "Kiên Giang", "Cần Thơ", "Hậu Giang", "Sóc Trăng", "Bạc Liêu", "Cà Mau"]
                };

                function getRegion(provinceName) {
                    if (!provinceName) return null;
                    for (let region in VN_REGIONS) {
                        if (VN_REGIONS[region].some(p => provinceName.includes(p) || p.includes(provinceName))) return region;
                    }
                    return null;
                }

                function sortRawWaypoints(start, end, stops) {
                    if (stops.length <= 1) return stops;
                    const vecAB = { lat: end.lat - start.lat, lng: end.lng - start.lng };
                    return stops.sort((a, b) => {
                        const projA = (a.lat - start.lat) * vecAB.lat + (a.lng - start.lng) * vecAB.lng;
                        const projB = (b.lat - start.lat) * vecAB.lat + (b.lng - start.lng) * vecAB.lng;
                        return projA - projB;
                    });
                }

                var markers = L.layerGroup().addTo(map);

                const iconBase = "https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-";
                const shadowUrl = "https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png";
                const createIcon = (color) => L.icon({
                    iconUrl: iconBase + color + ".png", shadowUrl: shadowUrl,
                    iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34], shadowSize: [41, 41]
                });

                var startPoint = null, endPoint = null;
                var intermediateStops = [];

                @if (Model.FromStationNavigation != null)
                {
                    <text>
                    var sLat = @((Model.FromStationNavigation.Latitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture));
                    var sLng = @((Model.FromStationNavigation.Longitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture));
                    if (sLat && sLng) {
                        startPoint = { lat: sLat, lng: sLng, icon: createIcon('blue'), name: '<b>Bắt đầu:</b> @Html.Raw(Model.FromStationNavigation.StationName)', province: '@Html.Raw(Model.FromStationNavigation.Province?.ProvinceName ?? "")' };
                    }
                    </text>
                }

                @if (Model.TripStations != null)
                {
                    foreach (var ts in Model.TripStations.OrderBy(x => x.StopOrder))
                    {
                        if (ts.Station != null)
                        {
                            <text>
                            var iLat = @((ts.Station.Latitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture));
                            var iLng = @((ts.Station.Longitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture));
                            if (iLat && iLng) {
                                intermediateStops.push({ lat: iLat, lng: iLng, icon: createIcon('orange'), name: '<b>Trạm đi qua:</b> @Html.Raw(ts.Station.StationName)', province: '@Html.Raw(ts.Station.Province?.ProvinceName ?? "")' });
                            }
                            </text>
                        }
                    }
                }

                @if (Model.ToStationNavigation != null)
                {
                    <text>
                    var eLat = @((Model.ToStationNavigation.Latitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture));
                    var eLng = @((Model.ToStationNavigation.Longitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture));
                    if (eLat && eLng) {
                        endPoint = { lat: eLat, lng: eLng, icon: createIcon('red'), name: '<b>Kết thúc:</b> @Html.Raw(Model.ToStationNavigation.StationName)', province: '@Html.Raw(Model.ToStationNavigation.Province?.ProvinceName ?? "")' };
                    }
                    </text>
                }

                if (startPoint && endPoint && intermediateStops.length > 0) {
                    intermediateStops = sortRawWaypoints(startPoint, endPoint, intermediateStops);
                }

                var rawWaypoints = [];
                if (startPoint) rawWaypoints.push(startPoint);
                intermediateStops.forEach(s => rawWaypoints.push(s));
                if (endPoint) rawWaypoints.push(endPoint);

                var startRegion = startPoint ? getRegion(startPoint.province) : null;
                var endRegion = endPoint ? getRegion(endPoint.province) : null;
                var sameRegion = (startRegion && endRegion && startRegion === endRegion);
                var isShortCrossRegion = false;
                
                if (startRegion && endRegion && !sameRegion) {
                    if ((startRegion === 'Central' && (endRegion === 'North' || endRegion === 'South')) ||
                        (endRegion === 'Central' && (startRegion === 'North' || startRegion === 'South'))) {
                        isShortCrossRegion = true;
                    }
                }

                var finalWaypoints = [];
                for (var i = 0; i < rawWaypoints.length; i++) {
                    var curr = rawWaypoints[i];
                    var latLng = L.latLng(curr.lat, curr.lng);
                    L.marker(latLng, { icon: curr.icon }).addTo(markers).bindPopup(curr.name);
                    finalWaypoints.push(latLng);

                    if (i < rawWaypoints.length - 1 && !sameRegion) {
                        var next = rawWaypoints[i+1];
                        var latDiff = Math.abs(curr.lat - next.lat);
                        var crossesWaist = (Math.min(curr.lat, next.lat) < 16.5 && Math.max(curr.lat, next.lat) > 19.5);
                        
                        if (latDiff > 2.5 || crossesWaist) { 
                            var minLat = Math.min(curr.lat, next.lat);
                            var maxLat = Math.max(curr.lat, next.lat);
                            var isNorthbound = (next.lat > curr.lat);
                            var applicablePoints = VN_CORRIDOR.filter(cp => cp.lat > minLat + 0.5 && cp.lat < maxLat - 0.5);
                            
                            if (isNorthbound) applicablePoints.sort((a,b) => a.lat - b.lat);
                            else applicablePoints.sort((a,b) => b.lat - a.lat);
                            
                            var maxAnchors = isShortCrossRegion ? 1 : 2;
                            if (applicablePoints.length > maxAnchors) {
                                if (maxAnchors === 1) applicablePoints = [applicablePoints[Math.floor(applicablePoints.length / 2)]];
                                else applicablePoints = [applicablePoints[0], applicablePoints[applicablePoints.length - 1]];
                            }
                            applicablePoints.forEach(cp => {
                                finalWaypoints.push(L.latLng(cp.lat, cp.lng));
                            });
                        }
                    }
                }

                if (finalWaypoints.length >= 2) {
                    routingControl.setWaypoints(finalWaypoints);
                    setTimeout(() => {
                        var group = new L.featureGroup(rawWaypoints.map(w => L.marker([w.lat, w.lng])));
                        map.fitBounds(group.getBounds().pad(0.2));
                    }, 500);
                }
            }
        });
    });
</script>            
        </div>
    </div>
</div>

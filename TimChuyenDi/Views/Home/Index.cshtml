@model IEnumerable<TimChuyenDi.Models.Trip>
@{
    ViewData["Title"] = "Trang chủ - Tìm Chuyến Đi";
}

<style>
    .map-banner {
        background: linear-gradient(135deg, #ffffff 0%, #f0f7ff 100%);
        border-radius: 15px;
        border: 1px solid #e0e9f5;
        transition: all 0.3s ease;
    }
    .map-banner:hover {
        box-shadow: 0 10px 20px rgba(13, 110, 253, 0.1) !important;
        transform: translateY(-2px);
    }
    .trip-card {
        border-radius: 12px;
        transition: all 0.2s ease;
    }
    .trip-card:hover {
        border-color: #0d6efd;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
    }
    .hover-scale {
        transition: all 0.3s ease;
    }
    .hover-scale:hover {
        transform: scale(1.02);
    }
</style>

<style>
    .hero-section {
        background: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url('/images/banner.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        padding: 100px 0 80px 0;
        border-radius: 0 0 40px 40px;
        color: white;
    }
    .hero-section h1 {
        text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
    }
    .hero-section p {
        text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
    }
    .map-banner {
        background: white;
        border-radius: 20px;
        border: 1px solid rgba(13, 110, 253, 0.1);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .map-banner:hover {
        box-shadow: 0 20px 40px rgba(13, 110, 253, 0.08) !important;
        transform: translateY(-5px);
    }
    .trip-card {
        border-radius: 18px;
        border: 1px solid #f0f0f0;
        transition: all 0.3s ease;
        overflow: hidden;
    }
    .trip-card:hover {
        border-color: #0d6efd;
        box-shadow: 0 15px 30px rgba(13, 110, 253, 0.1);
        transform: translateY(-5px);
    }
    .trip-header {
        background: linear-gradient(to right, #0d6efd, #0b5ed7);
        color: white;
        padding: 12px 20px;
        font-weight: 600;
    }
    .price-tag {
        background: #fff4e5;
        color: #e65100;
        padding: 4px 12px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.9rem;
    }
    .capacity-badge {
        background: #e7f3ff;
        color: #007bff;
        padding: 4px 12px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.85rem;
    }
</style>

<div class="hero-section mb-5 text-center">
    <div class="container text-center">
        <h1 class="display-3 fw-bold text-white mb-3 animate__animated animate__fadeIn">
             <i class="bi bi-bus-front"></i> Dịch vụ ghép hàng thông minh
        </h1>
        <p class="lead mb-4 text-white opacity-90 mx-auto" style="max-width: 800px;">
            Tìm chuyến nhanh chóng, ghép hàng liên tỉnh dễ dàng, tối ưu chi phí vận chuyển chỉ trong vài bước.
        </p>
        
        <div class="d-flex flex-wrap justify-content-center gap-3 mt-4">
            <a asp-controller="Customer" asp-action="CreateRequest" class="btn btn-primary btn-lg px-5 py-3 fw-bold rounded-pill shadow-lg hover-scale">
                <i class="bi bi-box-seam-fill me-2"></i> TẠO ĐƠN VẬN CHUYỂN NGAY
            </a>
        </div>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center mb-5">
        <div class="col-lg-9">
            <div class="map-banner p-4 shadow-sm">
                <div class="row align-items-center">
                    <div class="col-md-auto text-center mb-3 mb-md-0">
                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle d-inline-block">
                            <i class="bi bi-geo-alt-fill text-primary" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                    <div class="col-md">
                        <h4 class="fw-bold text-dark mb-1 text-center text-md-start">Tìm chuyến xe quanh bạn?</h4>
                        <p class="text-muted mb-0 text-center text-md-start small">Sử dụng tính năng định vị để tìm các chuyến xe đang ở gần khu vực lấy hàng của bạn.</p>
                    </div>
                    <div class="col-md-auto mt-3 mt-md-0 text-center">
                        <a asp-controller="Home" asp-action="Map" class="btn btn-dark btn-lg fw-bold px-4 rounded-pill">
                            <i class="bi bi-map me-2"></i> XEM BẢN ĐỒ
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="tripList" class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h5 class="fw-bold text-dark mb-0">
            <i class="bi bi-lightning-charge-fill text-warning me-2"></i>CHUYẾN XE MỚI CẬP NHẬT
        </h5>
        <div class="text-muted small">Cập nhật lúc: @DateTime.Now.ToString("HH:mm")</div>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card trip-card h-100 border-0 shadow-sm">
                        <div class="trip-header d-flex justify-content-between align-items-center">
                            <span>@item.FromStationNavigation.Province.ProvinceName <i class="bi bi-arrow-right mx-1"></i> @item.ToStationNavigation.Province.ProvinceName</span>
                        </div>
                        <div class="card-body p-4">
                            @{
                                double avgScore = 0;
                                if (ViewBag.AvgRatings != null && ViewBag.AvgRatings.ContainsKey(item.DriverId))
                                {
                                    avgScore = ViewBag.AvgRatings[item.DriverId];
                                }
                            }

                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-light rounded-circle p-2 me-2">
                                    <i class="bi bi-person-fill text-secondary"></i>
                                </div>
                                <div>
                                    <div class="fw-bold text-dark small">@item.Driver.Name</div>
                                    @if (avgScore > 0)
                                    {
                                        <div class="text-warning small"><i class="bi bi-star-fill"></i> @avgScore <span class="text-muted ms-1">(12 đánh giá)</span></div>
                                    }
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex align-items-start mb-2">
                                    <i class="bi bi-geo-alt text-primary mt-1 me-2"></i>
                                    <div class="small text-muted">@item.FromStationNavigation.StationName</div>
                                </div>
                                <div class="d-flex align-items-start mb-2">
                                    <i class="bi bi-flag text-danger mt-1 me-2"></i>
                                    <div class="small text-muted">@item.ToStationNavigation.StationName</div>
                                </div>
                                <div class="d-flex align-items-center text-primary fw-bold small">
                                    <i class="bi bi-calendar-event me-2"></i> @item.StartTime.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </div>

                            <hr class="my-3 opacity-10">

                        </div>
                        <div class="card-footer bg-light border-0 p-3 pt-0">
                            <div class="row g-2">
                                <div class="col-4">
                                    <a asp-controller="Customer" asp-action="SaveRoute" asp-route-id="@item.TripId" class="btn btn-light w-100 rounded-pill small py-2 border"><i class="bi bi-bookmark"></i></a>
                                </div>
                                <div class="col-8">
                                    <a asp-controller="Customer" asp-action="BookTrip" asp-route-id="@item.TripId" class="btn btn-primary w-100 rounded-pill fw-bold py-2 shadow-sm">GỬI YÊU CẦU</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 py-5 text-center text-muted">
                <div class="bg-light rounded-circle p-4 d-inline-block mb-3">
                    <i class="bi bi-search" style="font-size: 3rem;"></i>
                </div>
                <h5>Hiện tại chưa có chuyến xe nào</h5>
                <p>Vui lòng quay lại sau hoặc tạo đơn hàng để tài xế tìm bạn.</p>
            </div>
        }
    </div>
    <div id="stationList" class="mt-5 mb-5 pt-4">
        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
            <h5 class="fw-bold text-dark mb-0">
                <i class="bi bi-geo-alt-fill text-primary me-2"></i>HỆ THỐNG TRẠM XE GIÓ VIỆT
            </h5>
            <a asp-action="Map" class="btn btn-outline-primary btn-sm rounded-pill px-3">Xem tất cả trên bản đồ</a>
        </div>

        <div class="row g-4">
            @if (ViewBag.Stations != null)
            {
                foreach (var station in (List<TimChuyenDi.Models.Station>)ViewBag.Stations)
                {
                    <div class="col-lg-3 col-md-6">
                        <div class="card border-0 shadow-sm rounded-4 hover-scale h-100" style="background: #f8f9ff;">
                            <div class="card-body p-3">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-2">
                                        <i class="bi bi-building text-primary"></i>
                                    </div>
                                    <div class="fw-bold text-dark small text-truncate">@station.StationName</div>
                                </div>
                                <div class="text-muted small mb-3 text-truncate" style="min-height: 1.5rem;"><i class="bi bi-map me-1"></i> @station.Address (@station.Province.ProvinceName)</div>
                                <a href="/Customer/CreateRequest" class="btn btn-sm btn-white w-100 border rounded-pill py-1 fw-bold text-primary">GỬI HÀNG TẠI ĐÂY</a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-4 mb-5">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-controller="Home" asp-action="Index"
                       asp-route-fromProvinceId="@ViewBag.CurrentFrom"
                       asp-route-toProvinceId="@ViewBag.CurrentTo"
                       asp-route-cargoTypeId="@ViewBag.CurrentCargo"
                       asp-route-startDate="@ViewBag.CurrentDate"
                       asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var today = new Date().toISOString().split('T')[0];
        var dateInputs = document.querySelectorAll('input[type="date"]');
        dateInputs.forEach(input => {
            input.setAttribute('min', today);
        });
    });
</script>
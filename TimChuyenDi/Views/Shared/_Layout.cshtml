<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dịch Vụ Ghép Hàng</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>

    @{
        // 👉 Lấy role 1 lần duy nhất
        var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    }

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-primary mb-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-white" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-truck"></i> Gió Việt
                </a>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <!-- MENU BÊN TRÁI -->
                    <ul class="navbar-nav flex-grow-1">

                        <!-- Chưa đăng nhập -->
                        @if (!User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Tìm chuyến xe</a>
                            </li>
                        }

                        <!-- CUSTOMER (2) -->
                        @if (role == "2")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Tìm chuyến xe</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Customer" asp-action="MySavedRoutes">Tuyến đã lưu</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Customer" asp-action="RequestHistory">Lịch sử gửi hàng</a>
                            </li>
                        }

                        <!-- DRIVER (3) -->
                        @if (role == "3")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Driver" asp-action="Index">Duyệt yêu cầu</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Driver" asp-action="MyTrips">Chuyến xe của tôi</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Driver" asp-action="ManageVehicles">Quản lý Xe</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Driver" asp-action="MyReviews">Đánh giá của khách</a>
                            </li>
                        }

                        <!-- ADMIN (1) -->
                        @if (role == "1")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Admin" asp-action="Index">Quản lý Người dùng</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Admin" asp-action="ManageTrips">Quản lý Chuyến xe</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Admin" asp-action="ManageStations">Quản lý Trạm</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Admin" asp-action="ManageVehicles">Kho Xe</a>
                            </li>
                        }

                    </ul>

                    <!-- MENU BÊN PHẢI -->
                    <ul class="navbar-nav">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-light fw-bold">Xin chào, @User.Identity.Name!</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white btn btn-sm btn-danger ms-2"
                                   asp-controller="Auth" asp-action="Logout">Đăng xuất</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Auth" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white btn btn-sm btn-outline-light ms-2"
                                   asp-controller="Auth" asp-action="Register">Đăng ký</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer style="background-color:#05295d;" class="text-light py-5 mt-5 position-relative">
        <div class="container">
            <div class="row gx-5">
                <!-- Cột 1: Thông tin -->
                <div class="col-md-5 mb-4 mb-md-0">
                    <h5 class="fw-bold mb-4 d-flex align-items-center">
                        <i class="bi bi-truck me-2 fs-5"></i> Ghép Hàng Liên Tỉnh
                    </h5>
                    <p class="small text-white-50 lh-lg mb-4">
                        Nền tảng kết nối trực tiếp chủ hàng và nhà xe liên tỉnh trên toàn quốc. Chúng tôi mang đến giải pháp tối ưu chi phí vận chuyển, an toàn và nhanh chóng nhất.
                    </p>
                    <div class="text-white-50 small">
                        <p class="mb-3"><i class="bi bi-geo-alt-fill text-primary mt-1 float-start me-3"></i> Hà Nội, Việt Nam</p>
                        <p class="mb-3"><i class="bi bi-telephone-fill text-primary mt-1 float-start me-3"></i> Hotline: 1900 xxxx</p>
                        <p class="mb-0"><i class="bi bi-envelope-fill text-primary mt-1 float-start me-3"></i> Email: hotro@ghephang.vn</p>
                    </div>
                </div>

                <!-- Cột 2: Về Chúng Tôi -->
                <div class="col-md-3 mb-4 mb-md-0">
                    <h5 class="fw-bold mb-4">Về Chúng Tôi</h5>
                    <ul class="list-unstyled small lh-lg">
                        <li class="mb-3"><a href="#" class="text-decoration-none text-white-50 hover-text-white transition-all">Trang chủ</a></li>
                        <li class="mb-3"><a href="#" class="text-decoration-none text-white-50 hover-text-white transition-all">Tìm chuyến xe</a></li>
                        <li class="mb-3"><a href="#" class="text-decoration-none text-white-50 hover-text-white transition-all">Quy định & Chính sách</a></li>
                        <li><a href="#" class="text-decoration-none text-white-50 hover-text-white transition-all">Bảo mật thông tin</a></li>
                    </ul>
                </div>

                <!-- Cột 3: Kết Nối -->
                <div class="col-md-4">
                    <h5 class="fw-bold mb-4">Kết Nối</h5>
                    <p class="small text-white-50 lh-lg mb-4">
                        Theo dõi chúng tôi trên các nền tảng mạng xã hội để cập nhật những chuyến xe giá rẻ và khuyến mãi mới nhất.
                    </p>
                    <div class="d-flex">
                        <a href="#" class="text-white me-3 fs-5 bg-white bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center hover-bg-primary transition-all" style="width: 40px; height: 40px;">
                            <i class="bi bi-facebook"></i>
                        </a>
                        <a href="#" class="text-white me-3 fs-5 bg-white bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center hover-bg-primary transition-all" style="width: 40px; height: 40px;">
                            <i class="bi bi-youtube"></i>
                        </a>
                        <a href="#" class="text-white fs-5 bg-white bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center hover-bg-primary transition-all" style="width: 40px; height: 40px;">
                            <i class="bi bi-tiktok"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Nút Trợ Lý Sinh Ngữ nổi ở góc -->
        <a href="#" class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center shadow-lg" 
           style="position: fixed; bottom: 30px; right: 30px; width: 60px; height: 60px; z-index: 1050;" title="Hỗ trợ trực tuyến">
            <i class="bi bi-robot fs-3 text-white"></i>
        </a>
    </footer>

    <style>
        .hover-text-white:hover { color: #fff !important; }
        .hover-bg-primary:hover { background-color: var(--bs-primary) !important; color: #fff !important; opacity: 1 !important; }
        .transition-all { transition: all 0.3s ease; }
    </style>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
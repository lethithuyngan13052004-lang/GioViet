@{ ViewData["Title"] = "Đổi mật khẩu"; }

<div class="container py-5" style="max-width: 500px;">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-warning text-dark p-4 text-center">
            <i class="bi bi-key-fill" style="font-size: 2.5rem;"></i>
            <h4 class="fw-bold mt-2 mb-0">Đổi mật khẩu</h4>
        </div>
        <div class="card-body p-4">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger rounded-3"><i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.Error</div>
            }

            <form method="post" asp-action="ChangePassword">
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small">MẬT KHẨU HIỆN TẠI</label>
                    <input type="password" name="CurrentPassword" class="form-control rounded-3 py-2" placeholder="Nhập mật khẩu hiện tại" required />
                </div>
                <hr class="my-3">
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small">MẬT KHẨU MỚI</label>
                    <input type="password" name="NewPassword" class="form-control rounded-3 py-2" placeholder="Tối thiểu 6 ký tự" minlength="6" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small">XÁC NHẬN MẬT KHẨU MỚI</label>
                    <input type="password" name="ConfirmPassword" class="form-control rounded-3 py-2" placeholder="Nhập lại mật khẩu mới" minlength="6" required />
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-warning btn-lg rounded-pill fw-bold shadow-sm">
                        <i class="bi bi-check-lg me-2"></i>XÁC NHẬN ĐỔI
                    </button>
                    <a asp-action="Profile" class="btn btn-outline-secondary rounded-pill">
                        <i class="bi bi-arrow-left me-2"></i>Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    body { background-color: #f0f2f5; }
</style>

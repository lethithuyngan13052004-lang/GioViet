@{ ViewData["Title"] = "Quên mật khẩu"; }

<div class="container py-5" style="max-width: 500px;">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-danger text-white p-4 text-center">
            <i class="bi bi-shield-lock-fill" style="font-size: 2.5rem;"></i>
            <h4 class="fw-bold mt-2 mb-0">Quên mật khẩu</h4>
            <p class="mb-0 opacity-75 small">Nhập SĐT đã đăng ký để nhận mã OTP</p>
        </div>
        <div class="card-body p-4">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger rounded-3"><i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.Error</div>
            }

            <form method="post" asp-action="ForgotPassword">
                <div class="mb-4">
                    <label class="form-label fw-bold text-muted small">SỐ ĐIỆN THOẠI ĐÃ ĐĂNG KÝ</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0 rounded-start-3"><i class="bi bi-phone"></i></span>
                        <input type="tel" name="Phone" class="form-control rounded-end-3 py-2 border-0 bg-light" placeholder="0xxx xxx xxx" required />
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold shadow-sm">
                        <i class="bi bi-send me-2"></i>GỬI MÃ OTP
                    </button>
                    <a asp-action="Login" class="btn btn-outline-secondary rounded-pill">
                        <i class="bi bi-arrow-left me-2"></i>Quay lại đăng nhập
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    body { background-color: #f0f2f5; }
</style>

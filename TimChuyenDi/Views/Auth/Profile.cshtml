@model TimChuyenDi.Models.User
@{ ViewData["Title"] = "Thông tin cá nhân"; }

<div class="container py-5" style="max-width: 700px;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-primary text-white p-4">
            <div class="d-flex align-items-center">
                <div class="bg-white bg-opacity-25 p-3 rounded-circle me-3">
                    <i class="bi bi-person-fill text-white" style="font-size: 2rem;"></i>
                </div>
                <div>
                    <h4 class="mb-0 fw-bold">@Model.Name</h4>
                    <small class="opacity-75">@(Model.Role == 1 ? "Quản trị viên" : Model.Role == 3 ? "Tài xế" : "Khách hàng")</small>
                </div>
            </div>
        </div>
        <div class="card-body p-4">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger rounded-3"><i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.Error</div>
            }

            <form method="post" asp-action="Profile">
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small text-uppercase">Họ và tên</label>
                    <input type="text" name="Name" class="form-control rounded-3 py-2" value="@Model.Name" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small text-uppercase">Số điện thoại</label>
                    <input type="text" class="form-control rounded-3 py-2 bg-light" value="@Model.Phone" readonly disabled />
                    <small class="text-muted">Số điện thoại không thể thay đổi</small>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small text-uppercase">Email</label>
                    <input type="email" name="Email" class="form-control rounded-3 py-2" value="@Model.Email" placeholder="email@example.com" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small text-uppercase">Ngày tham gia</label>
                    <input type="text" class="form-control rounded-3 py-2 bg-light" value="@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")" readonly disabled />
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm">
                        <i class="bi bi-check-lg me-2"></i>LƯU THAY ĐỔI
                    </button>
                    <a asp-action="ChangePassword" class="btn btn-outline-warning rounded-pill fw-bold">
                        <i class="bi bi-key me-2"></i>ĐỔI MẬT KHẨU
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    body { background-color: #f0f2f5; }
</style>
